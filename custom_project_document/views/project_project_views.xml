<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_project_project_form_documents" model="ir.ui.view">
    <field name="name">project.project.form.documents</field>
    <field name="model">project.project</field>
    <field name="inherit_id" ref="project.edit_project"/>
    <field name="arch" type="xml">

      <!-- ── Smart buttons ── -->
      <xpath expr="//div[@name='button_box']" position="inside">

        <button name="action_view_documents"
                type="object"
                class="oe_stat_button"
                icon="fa-file-text-o"
                groups="project.group_project_user">
          <field name="document_count" string="Documents" widget="statinfo"/>
        </button>

        <button name="action_view_case_studies"
                type="object"
                class="oe_stat_button"
                icon="fa-book"
                groups="project.group_project_user">
          <field name="case_study_count" string="Case Studies" widget="statinfo"/>
        </button>

      </xpath>

      <!-- ── Tabs inside the project form ── -->
      <xpath expr="//sheet" position="inside">
        <notebook>

          <!-- Documents tab -->
          <page string="Documents" name="documents_tab"
                groups="project.group_project_manager,hr.group_hr_user">

            <field name="document_ids" mode="list"
                   context="{'default_project_id': id}">
              <list editable="bottom" create="1" delete="1"
                    decoration-success="document_type in ('contract', 'approval')"
                    decoration-info="document_type in ('blueprint', 'report', 'minutes')"
                    decoration-warning="document_type in ('invoice', 'handover')">

                <field name="name" string="Document Name"
                       placeholder="e.g. Contract, Blueprint" required="1"/>
                <field name="document_type" string="Category" required="1"
                       widget="badge"
                       decoration-success="document_type in ('contract', 'approval')"
                       decoration-info="document_type in ('blueprint', 'report', 'minutes')"
                       decoration-warning="document_type in ('invoice', 'handover')"/>
                <field name="file_type"   string="Type"        readonly="1"  optional="show"/>
                <field name="file" filename="filename" string="File"
                       widget="binary" required="1"                           optional="show"/>
                <field name="filename"    string="File Name"   readonly="1"  optional="hide"/>
                <field name="file_url"    string="Preview"     widget="url"
                       text="Preview" invisible="not file_url" readonly="1"  optional="show"/>
                <field name="upload_date" string="Uploaded On" readonly="1"  optional="show"/>
                <field name="uploaded_by" string="Uploaded By" readonly="1"  optional="hide"/>
                <field name="notes"       string="Notes"                      optional="hide"/>

              </list>
            </field>

          </page>

          <!-- Case Studies tab -->
          <page string="Case Studies" name="case_studies_tab"
                groups="project.group_project_manager,hr.group_hr_user">

            <field name="case_study_ids" mode="list"
                   context="{'default_project_id': id}">
              <list editable="bottom" create="1" delete="1"
                    decoration-success="case_study_type in ('client_success', 'business')"
                    decoration-info="case_study_type in ('technical', 'process_improvement')"
                    decoration-warning="case_study_type in ('risk_analysis', 'post_mortem')">

                <field name="name" string="Title"
                       placeholder="e.g. Q3 Onboarding Review" required="1"/>
                <field name="case_study_type" string="Type" required="1"
                       widget="badge"
                       decoration-success="case_study_type in ('client_success', 'business')"
                       decoration-info="case_study_type in ('technical', 'process_improvement')"
                       decoration-warning="case_study_type in ('risk_analysis', 'post_mortem')"/>
                <field name="summary"     string="Summary"       optional="show"/>
                <field name="file_type"   string="File Type"     readonly="1" optional="show"/>
                <field name="file" filename="filename" string="File"
                       widget="binary"                           optional="show"/>
                <field name="filename"    string="File Name"     readonly="1" optional="hide"/>
                <field name="file_url"    string="Preview"       widget="url"
                       text="Preview" invisible="not file_url" readonly="1"  optional="show"/>
                <field name="upload_date" string="Recorded On"   readonly="1" optional="show"/>
                <field name="uploaded_by" string="Recorded By"   readonly="1" optional="hide"/>
                <field name="notes"       string="Notes"                      optional="hide"/>

              </list>
            </field>

          </page>

        </notebook>
      </xpath>

    </field>
  </record>

</odoo>