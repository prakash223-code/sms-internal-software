<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         RECORD RULES: hr.attendance
         Employees see only their own records.
         HR and Attendance Manager see all.
    ================================================================ -->

    <record id="rule_attendance_employee_own" model="ir.rule">
        <field name="name">Attendance: Employee sees own records only</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_attendance_hr_all" model="ir.rule">
        <field name="name">Attendance: HR sees all records</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_attendance_manager_all" model="ir.rule">
        <field name="name">Attendance: Manager sees all records</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_attendance.group_hr_attendance_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ================================================================
         RECORD RULES: attendance.monthly.summary
         Employees see only their own summary.
         HR and Manager see all.
    ================================================================ -->

    <record id="rule_monthly_summary_employee_own" model="ir.rule">
        <field name="name">Monthly Summary: Employee sees own record only</field>
        <field name="model_id" ref="custom_attendance.model_attendance_monthly_summary"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_monthly_summary_hr_all" model="ir.rule">
        <field name="name">Monthly Summary: HR sees all records</field>
        <field name="model_id" ref="custom_attendance.model_attendance_monthly_summary"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_monthly_summary_manager_all" model="ir.rule">
        <field name="name">Monthly Summary: Manager sees all records</field>
        <field name="model_id" ref="custom_attendance.model_attendance_monthly_summary"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_attendance.group_hr_attendance_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>