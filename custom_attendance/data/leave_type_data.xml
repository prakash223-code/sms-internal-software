<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="leave_type_casual" model="hr.leave.type">
        <field name="name">Casual Leave</field>
        <field name="requires_allocation" eval="True"/>
        <field name="employee_requests" eval="True"/>
        <field name="allocation_validation_type">no_validation</field>
        <field name="leave_validation_type">hr</field>
        <field name="unpaid" eval="False"/>
        <field name="color" eval="4"/>
    </record>

    <record id="leave_type_earned" model="hr.leave.type">
        <field name="name">Earned Leave</field>
        <field name="requires_allocation" eval="True"/>
        <field name="employee_requests" eval="True"/>
        <field name="allocation_validation_type">no_validation</field>
        <field name="leave_validation_type">hr</field>
        <field name="unpaid" eval="False"/>
        <field name="color" eval="10"/>
    </record>

    <record id="leave_type_medical" model="hr.leave.type">
        <field name="name">Medical Leave</field>
        <field name="requires_allocation" eval="True"/>
        <field name="employee_requests" eval="True"/>
        <field name="allocation_validation_type">no_validation</field>
        <field name="leave_validation_type">hr</field>
        <field name="unpaid" eval="False"/>
        <field name="color" eval="1"/>
    </record>

    <record id="leave_type_permission" model="hr.leave.type">
        <field name="name">Permission</field>
        <field name="request_unit">hour</field>
        <field name="requires_allocation" eval="True"/>
        <field name="employee_requests" eval="True"/>
        <field name="allocation_validation_type">no_validation</field>
        <field name="leave_validation_type">hr</field>
        <field name="unpaid" eval="False"/>
        <field name="color" eval="7"/>
    </record>

</odoo>