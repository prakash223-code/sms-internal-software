<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_auto_checkout" model="ir.cron">
        <field name="name">Attendance: Auto Checkout at 19:00</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_checkout()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">5</field>
        <field name="nextcall">2025-01-01 13:45:00</field>
    </record>

    <record id="cron_generate_monthly_summary" model="ir.cron">
        <field name="name">Attendance: Generate Monthly Summary</field>
        <field name="model_id" ref="custom_attendance.model_attendance_monthly_summary"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_monthly_summary()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="priority">10</field>
        <field name="nextcall">2025-01-01 00:30:00</field>
    </record>

    <!-- Runs on Jan 1 every year — generates 2nd/4th Saturday resource
         leaves for current + next year so they appear greyed out in
         the Time Off calendar -->
    <record id="cron_generate_saturday_resource_leaves" model="ir.cron">
        <field name="name">Attendance: Generate Saturday Off Calendar Leaves</field>
        <field name="model_id" ref="custom_attendance.model_company_holiday"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_saturday_resource_leaves()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="priority">20</field>
        <field name="nextcall">2025-01-01 01:00:00</field>
    </record>

    <record id="cron_process_leave_anniversaries" model="ir.cron">
        <field name="name">Leave: Process Anniversary Carry-Forward</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_process_leave_anniversaries()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">15</field>
        <field name="nextcall">2025-01-01 01:30:00</field>
    </record>

    <record id="cron_generate_permission_allocation" model="ir.cron">
        <field name="name">Attendance: Generate Monthly Permission Allocation</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_monthly_permission_allocation()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="priority">12</field>
        <field name="nextcall">2025-01-01 00:15:00</field>
    </record>

</odoo>