<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- HR VIEW: Monthly Summary List -->
    <record id="view_monthly_summary_hr_list" model="ir.ui.view">
        <field name="name">attendance.monthly.summary.hr.list</field>
        <field name="model">attendance.monthly.summary</field>
        <field name="arch" type="xml">
            <list string="Monthly Attendance Summary"
                  delete="false"
                  decoration-warning="absent_days &gt; 0"
                  decoration-danger="unpaid_absent_days &gt; 3">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="working_days"/>
                <field name="present_days"/>
                <field name="late_days"/>
                <field name="leave_days"/>
                <field name="unpaid_leave_days"/>
                <field name="absent_days"/>
                <field name="unpaid_absent_days"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'draft'"/>
                <button name="action_compute" string="Recompute" type="object"
                        icon="fa-refresh" invisible="state == 'confirmed'"
                        confirm="This will overwrite existing values. Proceed?"/>
                <button name="action_confirm" string="Confirm" type="object"
                        icon="fa-check" invisible="state == 'confirmed'"
                        confirm="Confirming will lock this record. Are you sure?"/>
            </list>
        </field>
    </record>

    <!-- HR VIEW: Monthly Summary Form -->
    <record id="view_monthly_summary_hr_form" model="ir.ui.view">
        <field name="name">attendance.monthly.summary.hr.form</field>
        <field name="model">attendance.monthly.summary</field>
        <field name="arch" type="xml">
            <form string="Monthly Attendance Summary">
                <header>
                    <button name="action_compute"
                            string="Compute / Recompute"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'confirmed'"
                            confirm="This will overwrite current values. Proceed?"/>
                    <button name="action_confirm"
                            string="Confirm and Lock"
                            type="object"
                            class="btn-success"
                            invisible="state == 'confirmed'"
                            confirm="Once confirmed, values cannot be changed without resetting to draft. Proceed?"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="employee_id" readonly="id != False"/>
                            <field name="month" readonly="id != False"/>
                            <field name="year" readonly="id != False"/>
                        </group>
                    </group>
                    <group string="Attendance Breakdown">
                        <group>
                            <field name="working_days" readonly="1"/>
                            <field name="present_days" readonly="1"/>
                            <field name="late_days" readonly="1"/>
                        </group>
                        <group>
                            <field name="leave_days" readonly="1"/>
                            <field name="unpaid_leave_days" readonly="1"/>
                            <field name="absent_days" readonly="1"/>
                        </group>
                    </group>
                    <group string="Payroll Deduction Reference">
                        <field name="unpaid_absent_days" readonly="1"/>
                        <div class="alert alert-info" role="alert" invisible="state == 'confirmed'">
                            <strong>Note:</strong> Unpaid Absent Days = Absent Days + Unpaid Leave Days.
                            This value is used for payroll deduction calculation.
                        </div>
                        <div class="alert alert-success" role="alert" invisible="state == 'draft'">
                            <strong>Confirmed.</strong> This record is locked and will be used for payroll.
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- HR VIEW: Search — minimal safe syntax -->
    <record id="view_monthly_summary_search" model="ir.ui.view">
        <field name="name">attendance.monthly.summary.search</field>
        <field name="model">attendance.monthly.summary</field>
        <field name="arch" type="xml">
            <search string="Search Monthly Summary">
                <field name="employee_id"/>
                <field name="year"/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <filter string="Has Absences" name="filter_absent"
                        domain="[('absent_days', '&gt;', 0)]"/>
                <filter string="Has Unpaid Deductions" name="filter_unpaid"
                        domain="[('unpaid_absent_days', '&gt;', 0)]"/>
                <filter string="Has Late Entries" name="filter_late"
                        domain="[('late_days', '&gt;', 0)]"/>
                <separator/>
                <filter string="Group by Employee" name="group_employee"
                        context="{'group_by': 'employee_id'}"/>
                <filter string="Group by Month" name="group_month"
                        context="{'group_by': 'month'}"/>
                <filter string="Group by Year" name="group_year"
                        context="{'group_by': 'year'}"/>
                <filter string="Group by Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- EMPLOYEE VIEW: My Monthly Summary (read-only list) -->
    <record id="view_monthly_summary_employee_list" model="ir.ui.view">
        <field name="name">attendance.monthly.summary.employee.list</field>
        <field name="model">attendance.monthly.summary</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="My Monthly Summary"
                  create="false" edit="false" delete="false"
                  decoration-warning="absent_days &gt; 0">
                <field name="month"/>
                <field name="year"/>
                <field name="working_days"/>
                <field name="present_days"/>
                <field name="late_days"/>
                <field name="leave_days"/>
                <field name="absent_days"/>
                <field name="unpaid_absent_days"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- HR ACTION -->
    <record id="action_monthly_summary_hr" model="ir.actions.act_window">
        <field name="name">Monthly Attendance Summary</field>
        <field name="res_model">attendance.monthly.summary</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_monthly_summary_search"/>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_monthly_summary_hr_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_monthly_summary_hr_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No monthly summaries found.</p>
            <p>Summaries are generated automatically on the 1st of each month.</p>
        </field>
    </record>

    <!-- EMPLOYEE ACTION -->
    <record id="action_monthly_summary_employee" model="ir.actions.act_window">
        <field name="name">My Monthly Summary</field>
        <field name="res_model">attendance.monthly.summary</field>
        <field name="view_mode">list</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_monthly_summary_employee_list')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No monthly summaries available yet.</p>
        </field>
    </record>

</odoo>