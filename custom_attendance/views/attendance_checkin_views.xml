<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_checkin_wizard_form" model="ir.ui.view">
        <field name="name">attendance.checkin.wizard.form</field>
        <field name="model">attendance.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>

                    <!-- Dark header band -->
                    <div class="o_att_header_band">
                        <span class="o_att_header_label">Attendance</span>
                        <span class="o_att_header_title">
                            <field name="employee_id" readonly="1" nolabel="1"/>
                        </span>
                    </div>

                    <!-- Status badge row -->
                    <div class="mb-3">
                        <field name="status" readonly="1" widget="badge"
                               decoration-success="status == 'in'"
                               decoration-danger="status == 'out'"
                               decoration-info="status == 'done'"/>
                    </div>

                    <!-- Checked in: active session -->
                    <group string="Active Session" invisible="status != 'in'">
                        <field name="last_check_in" string="Checked In At" readonly="1"/>
                        <field name="is_late" readonly="1"/>
                        <field name="late_minutes" string="Late By (Minutes)"
                               readonly="1" invisible="not is_late"/>
                    </group>

                    <!-- Completed today -->
                    <group string="Today's Session" invisible="status != 'done'">
                        <field name="last_check_in" string="Checked In" readonly="1"/>
                        <field name="last_check_out" string="Checked Out" readonly="1"/>
                        <field name="is_late" readonly="1"/>
                        <field name="late_minutes" string="Late By (Minutes)"
                               readonly="1" invisible="not is_late"/>
                    </group>

                    <!-- Done info banner -->
                    <div invisible="status != 'done'" class="o_att_banner o_att_banner_done">
                        <strong>All done!</strong> Your attendance is complete for today.
                        Check-in is not permitted again until tomorrow.
                    </div>

                    <footer>
                        <button name="action_toggle" type="object"
                                class="btn btn-primary" string="Check In"
                                invisible="status != 'out'"/>
                        <button name="action_toggle" type="object"
                                class="btn btn-secondary" string="Check Out"
                                invisible="status != 'in'"/>
                        <button string="Close" class="btn btn-light" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_attendance_checkin_wizard" model="ir.actions.act_window">
        <field name="name">Check In / Check Out</field>
        <field name="res_model">attendance.checkin.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_attendance_checkin_wizard_form"/>
    </record>

</odoo>