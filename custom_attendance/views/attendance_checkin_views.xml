<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_checkin_wizard_form" model="ir.ui.view">
        <field name="name">attendance.checkin.wizard.form</field>
        <field name="model">attendance.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check In / Check Out">
                <sheet>

                    <!-- Employee header: avatar circle + name + status badge -->
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="o_att_avatar_circle">
                            <i class="fa fa-user" title="Employee"/>
                        </div>
                        <div class="flex-grow-1">
                            <div class="o_att_emp_name">
                                <field name="employee_id" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <div>
                            <field name="status" readonly="1" widget="badge"
                                   decoration-success="status == 'in'"
                                   decoration-danger="status == 'out'"
                                   decoration-info="status == 'done'"/>
                        </div>
                    </div>

                    <div class="o_att_divider"/>

                    <!-- CHECKED IN: active session -->
                    <div invisible="status != 'in'">
                        <div class="o_att_session_label">Active Session</div>
                        <div class="o_att_time_card">
                            <div class="o_att_time_sublabel">Checked in at</div>
                            <div class="o_att_time_value">
                                <field name="last_check_in" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <div invisible="not is_late"
                             class="o_att_banner o_att_banner_late mt-2">
                            ⚠ Late by
                            <field name="late_minutes" nolabel="1" readonly="1"/>
                            minutes — threshold is 9:30 AM
                        </div>
                    </div>

                    <!-- DONE: completed today -->
                    <div invisible="status != 'done'">
                        <div class="o_att_session_label">Today's Attendance</div>
                        <div class="d-flex gap-3">
                            <div class="o_att_time_card flex-fill">
                                <div class="o_att_time_sublabel">Check In</div>
                                <div class="o_att_time_value">
                                    <field name="last_check_in" readonly="1" nolabel="1"/>
                                </div>
                            </div>
                            <div class="o_att_time_card flex-fill">
                                <div class="o_att_time_sublabel">Check Out</div>
                                <div class="o_att_time_value">
                                    <field name="last_check_out" readonly="1" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="o_att_banner o_att_banner_done mt-2">
                            <strong>All done for today.</strong>
                            Your attendance is recorded. Check-in resumes tomorrow.
                        </div>
                    </div>

                    <!-- Hidden fields needed by invisible conditions -->
                    <field name="is_late" invisible="1"/>
                    <field name="late_minutes" invisible="1"/>

                </sheet>

                <footer>
                    <button name="action_toggle" type="object"
                            string="Check In" class="btn btn-primary"
                            invisible="status != 'out'"/>
                    <button name="action_toggle" type="object"
                            string="Check Out" class="btn btn-secondary"
                            invisible="status != 'in'"/>
                    <button string="Close" class="btn btn-light" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_checkin_wizard" model="ir.actions.act_window">
        <field name="name">Check In / Check Out</field>
        <field name="res_model">attendance.checkin.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_attendance_checkin_wizard_form"/>
    </record>

</odoo>