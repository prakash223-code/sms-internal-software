<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        All items nested inside Odoo's native Attendances root.
        Native menu sequences in Odoo 19:
          Management    → seq 10
          Reporting     → seq 20
          Configuration → seq 30
        Our items start at seq 40 onwards.
    -->

    <!-- ── Check In / Check Out ── visible to all employees ── -->
    <menuitem
        id="menu_checkin_checkout"
        name="Check In / Check Out"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_attendance_checkin_wizard"
        sequence="40"
        groups="base.group_user"/>

    <!-- ── My Attendance ── submenu for employees ── -->
    <menuitem
        id="menu_attendance_employee_section"
        name="My Attendance"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="50"
        groups="base.group_user"/>

    <menuitem
        id="menu_my_attendance"
        name="My Records"
        parent="menu_attendance_employee_section"
        action="action_my_attendance"
        sequence="10"
        groups="base.group_user"/>

    <menuitem
        id="menu_my_monthly_summary"
        name="My Monthly Summary"
        parent="menu_attendance_employee_section"
        action="action_monthly_summary_employee"
        sequence="20"
        groups="base.group_user"/>

    <!-- ── HR: All Attendance ── direct item, HR only ── -->
    <menuitem
        id="menu_hr_attendance_all"
        name="All Attendance"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_hr_attendance_all"
        sequence="60"
        groups="hr.group_hr_user,hr_attendance.group_hr_attendance_manager"/>

    <!-- ── HR: Monthly Summaries ── direct item, HR only ── -->
    <menuitem
        id="menu_hr_monthly_summary"
        name="Monthly Summaries"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_monthly_summary_hr"
        sequence="70"
        groups="hr.group_hr_user,hr_attendance.group_hr_attendance_manager"/>

    <!-- ── HR: Company Holidays ── direct item, HR only ── -->
    <menuitem
        id="menu_company_holidays"
        name="Company Holidays"
        parent="hr_attendance.menu_hr_attendance_root"
        action="action_company_holidays"
        sequence="80"
        groups="hr.group_hr_user,hr_attendance.group_hr_attendance_manager"/>

</odoo>