<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_summary_batch_wizard_form" model="ir.ui.view">
        <field name="name">attendance.summary.batch.wizard.form</field>
        <field name="model">attendance.summary.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Monthly Attendance Summaries">
                <sheet>

                    <!-- ── SETUP STATE ── -->
                    <group invisible="state != 'draft'">

                        <group string="Period">
                            <field name="month" widget="selection"/>
                            <field name="year"/>
                        </group>

                        <group string="Options">
                            <field name="overwrite_draft"/>
                        </group>

                        <group string="Employees" colspan="2">
                            <div class="o_field_widget" colspan="2">
                                <button name="action_select_all_employees"
                                        type="object"
                                        string="Select All Employees"
                                        class="btn btn-sm btn-secondary me-2"/>
                                <button name="action_clear_employees"
                                        type="object"
                                        string="Clear Selection"
                                        class="btn btn-sm btn-secondary"/>
                                <div class="text-muted mt-1" style="font-size:12px;">
                                    Leave empty to generate for <strong>all active employees</strong>.
                                </div>
                            </div>
                            <field name="employee_ids"
                                   widget="many2many_tags"
                                   placeholder="All active employees if empty..."
                                   nolabel="1"
                                   colspan="2"/>
                        </group>

                    </group>

                    <!-- ── RESULTS STATE ── -->
                    <group string="Batch Complete" invisible="state != 'done'">

                        <div class="alert alert-success" role="alert" colspan="2">
                            <strong>Batch generation complete!</strong>
                            Review the results below and click "View Summaries" to open them.
                        </div>

                        <group string="Results" colspan="2">
                            <field name="result_total"     readonly="1"/>
                            <field name="result_created"   readonly="1"/>
                            <field name="result_recomputed" readonly="1"/>
                            <field name="result_skipped"   readonly="1"/>
                        </group>

                        <div class="alert alert-info" role="alert"
                             colspan="2"
                             invisible="result_skipped == 0">
                            <strong>Note:</strong> Skipped summaries are either already
                            <em>Confirmed</em> (protected) or existing drafts when
                            "Recompute Existing Draft" was unchecked.
                        </div>

                    </group>

                    <field name="state" invisible="1"/>

                </sheet>

                <footer>
                    <!-- Setup state buttons -->
                    <button name="action_generate"
                            type="object"
                            string="Generate Summaries"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will create or recompute attendance summaries for the selected period. Confirmed summaries will not be touched. Proceed?"/>

                    <!-- Done state buttons -->
                    <button name="action_view_summaries"
                            type="object"
                            string="View Summaries"
                            class="btn-primary"
                            invisible="state != 'done'"/>

                    <button string="Close"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attendance_summary_batch_wizard" model="ir.actions.act_window">
        <field name="name">Generate Monthly Summaries (Batch)</field>
        <field name="res_model">attendance.summary.batch.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_attendance_summary_batch_wizard_form"/>
    </record>

</odoo>