<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="quote_01" model="welcome.quote">
        <field name="sequence">1</field>
        <field name="text">The secret of getting ahead is getting started.</field>
        <field name="author">Mark Twain</field>
    </record>

    <record id="quote_02" model="welcome.quote">
        <field name="sequence">2</field>
        <field name="text">Hard work beats talent when talent doesn't work hard.</field>
        <field name="author">Tim Notke</field>
    </record>

    <record id="quote_03" model="welcome.quote">
        <field name="sequence">3</field>
        <field name="text">The only way to do great work is to love what you do.</field>
        <field name="author">Steve Jobs</field>
    </record>

    <record id="quote_04" model="welcome.quote">
        <field name="sequence">4</field>
        <field name="text">Strive not to be a success, but rather to be of value.</field>
        <field name="author">Albert Einstein</field>
    </record>

    <record id="quote_05" model="welcome.quote">
        <field name="sequence">5</field>
        <field name="text">Don't watch the clock; do what it does. Keep going.</field>
        <field name="author">Sam Levenson</field>
    </record>

    <record id="quote_06" model="welcome.quote">
        <field name="sequence">6</field>
        <field name="text">The future depends on what you do today.</field>
        <field name="author">Mahatma Gandhi</field>
    </record>

    <record id="quote_07" model="welcome.quote">
        <field name="sequence">7</field>
        <field name="text">It always seems impossible until it's done.</field>
        <field name="author">Nelson Mandela</field>
    </record>

    <record id="quote_08" model="welcome.quote">
        <field name="sequence">8</field>
        <field name="text">Teamwork makes the dream work.</field>
        <field name="author">John C. Maxwell</field>
    </record>

    <record id="quote_09" model="welcome.quote">
        <field name="sequence">9</field>
        <field name="text">Coming together is a beginning, staying together is progress, working together is success.</field>
        <field name="author">Henry Ford</field>
    </record>

    <record id="quote_10" model="welcome.quote">
        <field name="sequence">10</field>
        <field name="text">Quality means doing it right when no one is looking.</field>
        <field name="author">Henry Ford</field>
    </record>

    <record id="quote_11" model="welcome.quote">
        <field name="sequence">11</field>
        <field name="text">Believe you can and you're halfway there.</field>
        <field name="author">Theodore Roosevelt</field>
    </record>

    <record id="quote_12" model="welcome.quote">
        <field name="sequence">12</field>
        <field name="text">Do what you can, with what you have, where you are.</field>
        <field name="author">Theodore Roosevelt</field>
    </record>

    <record id="quote_13" model="welcome.quote">
        <field name="sequence">13</field>
        <field name="text">Act as if what you do makes a difference. It does.</field>
        <field name="author">William James</field>
    </record>

    <record id="quote_14" model="welcome.quote">
        <field name="sequence">14</field>
        <field name="text">Success usually comes to those who are too busy to be looking for it.</field>
        <field name="author">Henry David Thoreau</field>
    </record>

    <record id="quote_15" model="welcome.quote">
        <field name="sequence">15</field>
        <field name="text">An investment in knowledge pays the best interest.</field>
        <field name="author">Benjamin Franklin</field>
    </record>

    <record id="quote_16" model="welcome.quote">
        <field name="sequence">16</field>
        <field name="text">I have not failed. I've just found 10,000 ways that won't work.</field>
        <field name="author">Thomas Edison</field>
    </record>

    <record id="quote_17" model="welcome.quote">
        <field name="sequence">17</field>
        <field name="text">The way to get started is to quit talking and begin doing.</field>
        <field name="author">Walt Disney</field>
    </record>

    <record id="quote_18" model="welcome.quote">
        <field name="sequence">18</field>
        <field name="text">You miss 100% of the shots you don't take.</field>
        <field name="author">Wayne Gretzky</field>
    </record>

    <record id="quote_19" model="welcome.quote">
        <field name="sequence">19</field>
        <field name="text">A person who never made a mistake never tried anything new.</field>
        <field name="author">Albert Einstein</field>
    </record>

    <record id="quote_20" model="welcome.quote">
        <field name="sequence">20</field>
        <field name="text">Great things in business are never done by one person; they're done by a team of people.</field>
        <field name="author">Steve Jobs</field>
    </record>

    <record id="quote_21" model="welcome.quote">
        <field name="sequence">21</field>
        <field name="text">The best time to plant a tree was 20 years ago. The second best time is now.</field>
        <field name="author">Chinese Proverb</field>
    </record>

    <record id="quote_22" model="welcome.quote">
        <field name="sequence">22</field>
        <field name="text">Success is not the key to happiness. Happiness is the key to success.</field>
        <field name="author">Albert Schweitzer</field>
    </record>

    <record id="quote_23" model="welcome.quote">
        <field name="sequence">23</field>
        <field name="text">The only limit to our realization of tomorrow is our doubts of today.</field>
        <field name="author">Franklin D. Roosevelt</field>
    </record>

    <record id="quote_24" model="welcome.quote">
        <field name="sequence">24</field>
        <field name="text">Opportunities don't happen. You create them.</field>
        <field name="author">Chris Grosser</field>
    </record>

    <record id="quote_25" model="welcome.quote">
        <field name="sequence">25</field>
        <field name="text">Don't be afraid to give up the good to go for the great.</field>
        <field name="author">John D. Rockefeller</field>
    </record>

    <record id="quote_26" model="welcome.quote">
        <field name="sequence">26</field>
        <field name="text">If you want to achieve greatness, stop asking for permission.</field>
        <field name="author">Anonymous</field>
    </record>

    <record id="quote_27" model="welcome.quote">
        <field name="sequence">27</field>
        <field name="text">Things work out best for those who make the best of how things work out.</field>
        <field name="author">John Wooden</field>
    </record>

    <record id="quote_28" model="welcome.quote">
        <field name="sequence">28</field>
        <field name="text">To live a creative life, we must lose our fear of being wrong.</field>
        <field name="author">Joseph Chilton Pearce</field>
    </record>

    <record id="quote_29" model="welcome.quote">
        <field name="sequence">29</field>
        <field name="text">If you are not willing to risk the usual, you will have to settle for the ordinary.</field>
        <field name="author">Jim Rohn</field>
    </record>

    <record id="quote_30" model="welcome.quote">
        <field name="sequence">30</field>
        <field name="text">All our dreams can come true, if we have the courage to pursue them.</field>
        <field name="author">Walt Disney</field>
    </record>

</odoo>