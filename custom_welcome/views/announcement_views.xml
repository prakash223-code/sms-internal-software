<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         LIST
    ================================================================ -->
    <record id="view_company_announcement_list" model="ir.ui.view">
        <field name="name">company.announcement.list</field>
        <field name="model">company.announcement</field>
        <field name="arch" type="xml">
            <list string="Company Announcements"
                  default_order="is_pinned desc, date desc"
                  decoration-info="is_pinned == True">
                <field name="is_pinned" string="📌" widget="boolean_toggle"/>
                <field name="date"      string="Posted On"/>
                <field name="title"     string="Title"/>
                <field name="posted_by" string="Posted By"/>
                <field name="active"    column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         FORM
    ================================================================ -->
    <record id="view_company_announcement_form" model="ir.ui.view">
        <field name="name">company.announcement.form</field>
        <field name="model">company.announcement</field>
        <field name="arch" type="xml">
            <form string="Company Announcement">
                <sheet>

                    <!-- Pinned banner -->
                    <div invisible="not is_pinned"
                         class="o_att_banner o_att_banner_compensatory mb-3">
                        <i class="fa fa-thumb-tack" title="Pinned"/>
                        <strong> Pinned</strong> — this announcement appears
                        at the top of every employee's welcome page.
                    </div>

                    <div class="oe_title mb-3">
                        <h1>
                            <field name="title"
                                   placeholder="e.g. Office closed on Monday 2 June…"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Details">
                            <field name="date"      string="Posted On"/>
                            <field name="posted_by" string="Posted By"/>
                            <field name="is_pinned" string="Pin to top of dashboard"/>
                            <field name="active"    string="Active (visible on dashboard)"/>
                        </group>
                    </group>

                    <group string="Body (optional)">
                        <field name="body"
                               nolabel="1"
                               placeholder="Optional extra details shown as a sub-line on the dashboard…"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         SEARCH
    ================================================================ -->
    <record id="view_company_announcement_search" model="ir.ui.view">
        <field name="name">company.announcement.search</field>
        <field name="model">company.announcement</field>
        <field name="arch" type="xml">
            <search string="Search Announcements">
                <field name="title"/>
                <field name="posted_by"/>
                <separator/>
                <filter string="Pinned"  name="filter_pinned"
                        domain="[('is_pinned', '=', True)]"/>
                <filter string="Active"  name="filter_active"
                        domain="[('active', '=', True)]"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Group by Month" name="group_month"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ================================================================
         ACTION
    ================================================================ -->
    <record id="action_company_announcements" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">company.announcement</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="search_view_id" ref="view_company_announcement_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No announcements yet.
            </p>
            <p>
                Create an announcement here and it will appear on every
                employee's welcome dashboard automatically.
                <br/>
                Use <strong>Pin to top</strong> for urgent notices.
            </p>
        </field>
    </record>

    <!-- ================================================================
         MENU  — nested under the existing Home / Welcome menu
         HR-only: only group_hr_user and above can manage announcements
    ================================================================ -->
    <menuitem
            id="menu_company_announcements"
            name="Announcements"
            parent="custom_welcome.menu_welcome_root"
            action="action_company_announcements"
            sequence="10"
            groups="hr.group_hr_user"/>

</odoo>