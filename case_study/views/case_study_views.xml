<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== STAGE VIEWS ========== -->

    <record id="case_study_stage_list" model="ir.ui.view">
        <field name="name">case.study.stage.list</field>
        <field name="model">case.study.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <record id="action_case_study_stage" model="ir.actions.act_window">
        <field name="name">Stages</field>
        <field name="res_model">case.study.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========== DEPARTMENT VIEWS ========== -->

    <record id="case_study_department_kanban" model="ir.ui.view">
        <field name="name">case.study.department.kanban</field>
        <field name="model">case.study.department</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard">
                <field name="name"/>
                <field name="code"/>
                <field name="case_study_count"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="p-3">
                            <strong class="fs-5">
                                <field name="name"/>
                            </strong>
                            <div class="text-muted" t-if="record.code.value">
                                <field name="code"/>
                            </div>
                            <div class="mt-2">
                                <!-- ✅ Click pannaa stages kaattum -->
                                <button name="action_view_case_studies"
                                        type="object"
                                        class="btn btn-primary btn-sm">
                                    <field name="case_study_count"/>
                                    Case Studies
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="case_study_department_list" model="ir.ui.view">
        <field name="name">case.study.department.list</field>
        <field name="model">case.study.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="case_study_count" string="Case Studies"/>
            </list>
        </field>
    </record>

    <record id="case_study_department_form" model="ir.ui.view">
        <field name="name">case.study.department.form</field>
        <field name="model">case.study.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                    </group>
                    <field name="description" placeholder="Description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_case_study_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">case.study.department</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ========== SOFTWARE VIEWS (dropdown list for Timesheet) ========== -->

    <record id="case_study_software_list" model="ir.ui.view">
        <field name="name">case.study.software.list</field>
        <field name="model">case.study.software</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_case_study_software" model="ir.actions.act_window">
        <field name="name">Software</field>
        <field name="res_model">case.study.software</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========== TAG VIEWS ========== -->

    <record id="case_study_tag_list" model="ir.ui.view">
        <field name="name">case.study.tag.list</field>
        <field name="model">case.study.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_case_study_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">case.study.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========== CASE STUDY VIEWS ========== -->

    <record id="case_study_kanban" model="ir.ui.view">
        <field name="name">case.study.kanban</field>
        <field name="model">case.study</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    quick_create="false"
                    group_create="false">
                <field name="name"/>
                <field name="stage_id"/>
                <field name="department_id"/>
                <field name="user_id"/>
                <field name="total_hours"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-2">
                            <strong>
                                <field name="name"/>
                            </strong>
                            <div class="text-muted small">
                                <field name="department_id"/>
                            </div>
                            <div class="d-flex justify-content-between
                                        align-items-center mt-2">
                                <field name="user_id"
                                       widget="many2one_avatar_user"/>
                                <span class="badge bg-info small">
                                    <field name="total_hours"/> h
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="case_study_list" model="ir.ui.view">
        <field name="name">case.study.list</field>
        <field name="model">case.study</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="department_id"/>
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="priority" widget="priority"/>
                <field name="total_hours" sum="Total Hours"/>
            </list>
        </field>
    </record>

    <record id="case_study_form" model="ir.ui.view">
        <field name="name">case.study.form</field>
        <field name="model">case.study</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- ✅ Confirm = left side (locks the record) -->
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary"
                            invisible="locked"/>
                    <button name="action_draft" type="object"
                            string="Set to Draft"
                            invisible="not locked"/>
                    <!-- statusbar auto-aligns to the right -->
                    <field name="stage_id"
                           widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="locked" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_project" type="object"
                                class="oe_stat_button" icon="fa-folder-open-o"
                                invisible="not project_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Open</span>
                                <span class="o_stat_text">Project</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label text-muted">
                            <field name="code" readonly="1"/>
                        </span>
                        <h1 class="d-flex align-items-center gap-2">
                            <field name="name" placeholder="Case Study Title"
                                   readonly="locked"/>
                            <field name="priority" widget="priority"
                                   readonly="locked"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"
                               placeholder="Tags..." readonly="locked"/>
                    </div>
                    <group>
                        <group>
                            <field name="department_id" readonly="locked"/>
                            <field name="project_id" readonly="locked"/>
                            <field name="partner_id" readonly="locked"/>
                            <field name="user_id" readonly="locked"/>
                            <field name="team_user_ids" widget="many2many_tags_avatar"
                                   readonly="locked"/>
                        </group>
                        <group>
                            <field name="date_start" readonly="locked"/>
                            <field name="date_end" readonly="locked"/>
                            <field name="planned_hours" readonly="locked"/>
                            <field name="total_hours" widget="progressbar"
                                   options="{'current_value': 'total_hours', 'max_value': 'planned_hours'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Short overview of the case study..."
                                   readonly="locked"/>
                        </page>

                        <page string="Case Study" name="case_study_details">
                            <separator string="Problem Statement"/>
                            <field name="problem_statement"
                                   placeholder="What problem/requirement did the client have?"
                                   readonly="locked" nolabel="1"/>
                            <separator string="Objective / Scope"/>
                            <field name="objective"
                                   placeholder="What exactly was analyzed / delivered?"
                                   readonly="locked" nolabel="1"/>
                            <separator string="Methodology / Approach"/>
                            <field name="methodology"
                                   placeholder="How was the work carried out - steps, standards, simulation type..."
                                   readonly="locked" nolabel="1"/>
                            <separator string="Challenges Faced"/>
                            <field name="challenges"
                                   placeholder="Any technical/practical difficulties and how they were solved..."
                                   readonly="locked" nolabel="1"/>
                            <separator string="Results / Outcome"/>
                            <field name="results"
                                   placeholder="Key findings, improvements, numbers achieved..."
                                   readonly="locked" nolabel="1"/>
                            <separator string="Conclusion"/>
                            <field name="conclusion"
                                   placeholder="Summary and recommendations..."
                                   readonly="locked" nolabel="1"/>
                        </page>

                        <page string="Documents" name="documents">
                            <field name="document_ids" readonly="locked">
                                <list editable="bottom">
                                    <field name="name" string="Document Name"/>
                                    <field name="category" string="Category"/>
                                    <field name="type" string="Type" readonly="1"/>
                                    <field name="file_data" filename="file_name"
                                           string="File"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="preview" widget="image"
                                           string="Preview"
                                           options="{'size': [40, 40]}"/>
                                    <field name="uploaded_on" string="Uploaded On"/>
                                </list>
                            </field>
                        </page>

                        <page string="Timesheet" name="timesheet">
                            <field name="timesheet_ids" readonly="locked">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="employee_id"/>
                                    <field name="project_id"/>
                                    <field name="task_id"/>
                                    <field name="software_id"/>
                                    <field name="description"/>
                                    <field name="hours"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_case_study" model="ir.actions.act_window">
        <field name="name">Case Studies</field>
        <field name="res_model">case.study</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ========== MENUS ========== -->

    <menuitem id="menu_case_study_root"
              name="Case Study"
              action="action_case_study_department"
              sequence="50"
              web_icon="case_study,static/description/icon.png"/>

    <!-- ✅ HR & Manager ku mattum - department vaariya illama, ella
         case studies-um one list la kaattum -->
    <menuitem id="menu_case_study_all"
              name="All Case Studies"
              parent="menu_case_study_root"
              action="action_case_study"
              sequence="5"
              groups="hr.group_hr_user,hr.group_hr_manager"/>

    <menuitem id="menu_case_study_config"
              name="Configuration"
              parent="menu_case_study_root"
              sequence="100"/>

    <menuitem id="menu_case_study_dept"
              name="Departments"
              parent="menu_case_study_config"
              action="action_case_study_department"
              sequence="10"/>

    <menuitem id="menu_case_study_stage"
              name="Stages"
              parent="menu_case_study_config"
              action="action_case_study_stage"
              sequence="20"/>

    <menuitem id="menu_case_study_software"
              name="Software"
              parent="menu_case_study_config"
              action="action_case_study_software"
              sequence="30"/>

    <menuitem id="menu_case_study_tag"
              name="Tags"
              parent="menu_case_study_config"
              action="action_case_study_tag"
              sequence="40"/>

</odoo>