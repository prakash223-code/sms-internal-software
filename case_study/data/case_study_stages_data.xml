<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="case_study_stage_todo" model="case.study.stage">
            <field name="name">To Do</field>
            <field name="sequence">10</field>
        </record>

        <record id="case_study_stage_in_progress" model="case.study.stage">
            <field name="name">In Progress</field>
            <field name="sequence">20</field>
        </record>

        <record id="case_study_stage_complete" model="case.study.stage">
            <field name="name">Complete</field>
            <field name="sequence">30</field>
            <field name="fold">True</field>
        </record>

        <record id="case_study_dept_cfd" model="case.study.department">
            <field name="name">CFD</field>
            <field name="code">CFD</field>
            <field name="sequence">10</field>
        </record>

        <record id="case_study_dept_fea" model="case.study.department">
            <field name="name">FEA</field>
            <field name="code">FEA</field>
            <field name="sequence">20</field>
        </record>

        <record id="case_study_dept_erp" model="case.study.department">
            <field name="name">Odoo ERP</field>
            <field name="code">ERP</field>
            <field name="sequence">30</field>
        </record>

    </data>
</odoo>