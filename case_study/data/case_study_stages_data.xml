        </record>

        <record id="case_study_dept_dm" model="case.study.department">
            <field name="name">Digital Marketing</field>
            <field name="code">DM</field>
            <field name="sequence">50</field>
        </record>

        <record id="case_study_dept_hr" model="case.study.department">
            <field name="name">Human Resources</field>
