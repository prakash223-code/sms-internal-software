            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ══ case.study.document ═════════════════════════════════════════
             Previously had NO rule at all — see prior fix. Now split the
             same way as the other two models.
        ═════════════════════════════════════════════════════════════════ -->

        <record id="rule_case_study_document_employee_read_all" model="ir.rule">
