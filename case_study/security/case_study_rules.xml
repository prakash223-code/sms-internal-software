        <record id="rule_case_study_timesheet_employee_write_own" model="ir.rule">
            <field name="name">Case Study Timesheet: Employee writes only if assigned</field>
            <field name="model_id" ref="model_case_study_timesheet"/>
            <field name="domain_force">
                [('case_study_id.assigned_employee_ids.user_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_case_study_timesheet_hr" model="ir.rule">
            <field name="name">Case Study Timesheet: HR sees all</field>
            <field name="model_id" ref="model_case_study_timesheet"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
