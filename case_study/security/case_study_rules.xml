<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══ case.study ═══════════════════════════════════════════════════
             Split into two employee rules so read and write can differ:
             every internal user can READ all case studies; only employees
             listed in assigned_employee_ids can WRITE one.
        ═════════════════════════════════════════════════════════════════ -->

        <record id="rule_case_study_employee_read_all" model="ir.rule">
            <field name="name">Case Study: Employee reads all (read-only browse)</field>
            <field name="model_id" ref="model_case_study"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_case_study_employee_write_own" model="ir.rule">
            <field name="name">Case Study: Employee writes only if assigned</field>
            <field name="model_id" ref="model_case_study"/>
            <field name="domain_force">
                [('assigned_employee_ids.user_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- HR/Manager: unrestricted, as before -->
        <record id="rule_case_study_hr" model="ir.rule">
            <field name="name">Case Study: HR sees all</field>
            <field name="model_id" ref="model_case_study"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ══ case.study.timesheet ═══════════════════════════════════════ -->

        <record id="rule_case_study_timesheet_employee_read_all" model="ir.rule">
