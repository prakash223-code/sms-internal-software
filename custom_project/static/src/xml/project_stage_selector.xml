<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="custom_project.KanbanColumnQuickCreate"
       t-inherit="web.KanbanColumnQuickCreate"
       t-inherit-mode="extension">

        <!-- Inject select BEFORE the native input -->
        <xpath expr="//input[@t-ref='autofocus']" position="before">
            <t t-if="isTaskTypeGroup">
                <select class="form-select form-select-sm o_cp_stage_select"
                        t-on-change="onStageSelect">
                    <option value="">— select a stage —</option>
                    <t t-foreach="stageDropdown.stages" t-as="s" t-key="s.id">
                        <option t-att-value="s.id">
                            <t t-esc="s.name"/>
                        </option>
                    </t>
                </select>
            </t>
        </xpath>

        <!-- Hide the native input when our select is active -->
        <!-- FIX: OWL uses JavaScript expressions — "not x" is invalid, "!x" is correct -->
        <xpath expr="//input[@t-ref='autofocus']" position="attributes">
            <attribute name="t-if">!isTaskTypeGroup</attribute>
        </xpath>

    </t>

</templates>