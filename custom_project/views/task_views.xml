<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ 1. Inherit project.task form — add custom fields ═══════════════ -->
    <record id="view_task_form_team_fields" model="ir.ui.view">
        <field name="name">project.task.form.team.fields</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <!-- Smart button for assignment requests -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_assignment_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-exchange"
                        invisible="assignment_request_count == 0">
                    <field name="assignment_request_count"
                           widget="statinfo"
                           string="Requests"/>
                </button>
            </xpath>

            <!-- State bar -->
            <xpath expr="//header" position="inside">
                <field name="task_state"
                       widget="statusbar"
                       statusbar_visible="draft,assigned,in_progress,completed,verified,closed"/>

                <button name="action_start_progress"
                        string="Start"
                        type="object"
                        class="btn-primary"
                        invisible="task_state != 'assigned'"/>
                <button name="action_mark_completed"
                        string="Mark Complete"
                        type="object"
                        class="btn-primary"
                        invisible="task_state != 'in_progress'"/>
                <button name="action_verify"
                        string="Verify"
                        type="object"
                        class="btn-primary"
                        invisible="task_state != 'completed'"/>
                <button name="action_close"
                        string="Close"
                        type="object"
                        class="btn-primary"
                        invisible="task_state != 'verified'"/>
                <button name="action_reset_to_draft"
                        string="Reset to Draft"
                        type="object"
                        groups="custom_project.group_team_manager"
                        invisible="task_state == 'draft'"/>
            </xpath>

            <!-- Custom fields group — inserted before description/notes -->
            <xpath expr="//field[@name='description']" position="before">
                <separator string="Team Assignment"/>
                <group>
                    <group>
                        <field name="team_id"
                               options="{'no_create_edit': True}"
                               domain="[('active','=',True)]"/>
                        <field name="assigned_by"
                               widget="many2one_avatar_employee"
                               readonly="1"/>
                    </group>
                    <group>
                        <field name="assigned_to"
                               widget="many2one_avatar_employee"
                               options="{'no_create_edit': True}"/>
                        <field name="task_priority" widget="priority"/>
                    </group>
                </group>

                <!-- Hidden field needed for conditional rendering -->
                <field name="assignment_request_count" invisible="1"/>
            </xpath>

        </field>
    </record>

    <!-- ══ 2. Standalone Kanban — grouped by task_state ═══════════════════ -->
    <record id="view_task_kanban_team" model="ir.ui.view">
        <field name="name">project.task.kanban.team</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="task_state"
                    class="o_kanban_small_column"
                    on_create="quick_create">
                <field name="name"/>
                <field name="task_state"/>
                <field name="task_priority"/>
                <field name="assigned_to"/>
                <field name="team_id"/>
                <field name="project_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_cp_task_card">
                            <div class="o_cp_task_card_top">
                                <span class="o_cp_task_name">
                                    <field name="name"/>
                                </span>
                                <span t-attf-class="o_cp_priority_badge o_cp_priority_#{record.task_priority.raw_value}">
                                    <t t-esc="record.task_priority.value"/>
                                </span>
                            </div>
                            <div class="o_cp_task_card_meta">
                                <span t-if="record.project_id.value" class="o_cp_task_meta_item">
                                    <i class="fa fa-folder-o" title="Project"/>
                                    <t t-esc="record.project_id.value"/>
                                </span>
                                <span t-if="record.team_id.value" class="o_cp_task_meta_item">
                                    <i class="fa fa-users" title="Team"/>
                                    <t t-esc="record.team_id.value"/>
                                </span>
                            </div>
                            <div class="o_cp_task_card_footer">
                                <field name="assigned_to"
                                       widget="many2one_avatar_employee"
                                       readonly="1"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══ 3. Standalone List ═════════════════════════════════════════════ -->
    <record id="view_task_list_team" model="ir.ui.view">
        <field name="name">project.task.list.team</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <list string="Tasks"
                  decoration-success="task_state == 'closed'"
                  decoration-info="task_state == 'in_progress'"
                  decoration-warning="task_state == 'draft'">
                <field name="name"            string="Task"/>
                <field name="team_id"         string="Team"/>
                <field name="project_id"      string="Project" optional="show"/>
                <field name="assigned_by"     string="Assigned By"
                       widget="many2one_avatar_employee" optional="show"/>
                <field name="assigned_to"     string="Assigned To"
                       widget="many2one_avatar_employee"/>
                <field name="task_priority"   string="Priority"
                       widget="badge"
                       decoration-danger="task_priority == 'critical'"
                       decoration-warning="task_priority == 'high'"
                       decoration-info="task_priority == 'normal'"
                       decoration-secondary="task_priority == 'low'"/>
                <field name="task_state"      string="State"
                       widget="badge"
                       decoration-success="task_state in ('verified','closed')"
                       decoration-info="task_state == 'in_progress'"
                       decoration-warning="task_state == 'draft'"
                       decoration-primary="task_state == 'assigned'"
                       decoration-muted="task_state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- ══ 4. Search view ════════════════════════════════════════════════ -->
    <record id="view_task_search_team" model="ir.ui.view">
        <field name="name">project.task.search.team</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <search string="Search Tasks">
                <field name="name"        string="Task Name"/>
                <field name="assigned_to" string="Assigned To"/>
                <field name="team_id"     string="Team"/>
                <field name="project_id"  string="Project"/>
                <separator/>
                <!-- State filters -->
                <filter string="Draft"       name="draft"
                        domain="[('task_state','=','draft')]"/>
                <filter string="Assigned"    name="assigned"
                        domain="[('task_state','=','assigned')]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('task_state','=','in_progress')]"/>
                <filter string="Completed"   name="completed"
                        domain="[('task_state','=','completed')]"/>
                <filter string="Closed"      name="closed"
                        domain="[('task_state','=','closed')]"/>
                <separator/>
                <!-- My tasks -->
                <filter string="My Tasks" name="my_tasks"
                        domain="[('assigned_to.user_id','=',uid)]"/>
                <separator/>
                <filter string="Group by Team"     name="grp_team"
                            context="{'group_by': 'team_id'}"/>
                <filter string="Group by State" name="grp_state"
                        context="{'group_by': 'task_state'}"/>
                <filter string="Group by Priority" name="grp_priority"
                        context="{'group_by': 'task_priority'}"/>
                <filter string="Group by Project" name="grp_project"
                        context="{'group_by': 'project_id'}"/>
            </search>
        </field>
    </record>

    <!-- ══ 5. Action — My Tasks (all roles) ════════════════════════════════ -->
    <record id="action_my_tasks" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_task_kanban_team')}),
            (0, 0, {'view_mode': 'list',   'view_id': ref('view_task_list_team')}),
        ]"/>
        <field name="domain">[('assigned_to.user_id','=', uid)]</field>
        <field name="search_view_id" ref="view_task_search_team"/>
        <field name="context">{'search_default_my_tasks': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks assigned to you yet.
            </p>
        </field>
    </record>

    <!-- ══ 6. Action — All Tasks (manager / team lead) ═════════════════════ -->
    <record id="action_all_tasks" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_task_kanban_team')}),
            (0, 0, {'view_mode': 'list',   'view_id': ref('view_task_list_team')}),
        ]"/>
        <field name="search_view_id" ref="view_task_search_team"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tasks found.
            </p>
        </field>
    </record>

</odoo>