<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ Form view ══════════════════════════════════════════════════════ -->
    <record id="view_team_form" model="ir.ui.view">
        <field name="name">team.team.form</field>
        <field name="model">team.team</field>
        <field name="arch" type="xml">
            <form string="Team">

                <sheet>

                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_tasks"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-tasks">
                            <field name="task_count"
                                   widget="statinfo"
                                   string="Tasks"/>
                        </button>

                        <button name="action_view_members"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="member_count"
                                   widget="statinfo"
                                   string="Members"/>
                        </button>

                    </div>

                    <!-- Header info -->
                    <div class="oe_title">
                        <label for="name" string="Team Name"/>
                        <h1>
                            <field name="name"
                                   placeholder="e.g. Backend Engineering"
                                   style="width: 100%;"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Team Details">
                            <field name="team_lead_id"
                                   widget="many2one_avatar_employee"
                                   options="{'no_create_edit': True}"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="About">
                            <field name="description"
                                   placeholder="Optional team description…"
                                   colspan="2"
                                   nolabel="1"/>
                        </group>
                    </group>

                    <!-- Members tab -->
                    <notebook>
                        <page string="Members" icon="fa-users">
                            <field name="member_ids"
                                   widget="many2many_tags"
                                   options="{'no_create_edit': True}"
                                   domain="[('active', '=', True)]"/>
                        </page>
                    </notebook>

                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- ══ List view ══════════════════════════════════════════════════════ -->
    <record id="view_team_list" model="ir.ui.view">
        <field name="name">team.team.list</field>
        <field name="model">team.team</field>
        <field name="arch" type="xml">
            <list string="Teams" decoration-muted="not active">
                <field name="name"/>
                <field name="team_lead_id" widget="many2one_avatar_employee"/>
                <field name="member_count"  string="Members"/>
                <field name="task_count"    string="Tasks"/>
                <field name="active"        column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ══ Kanban view ════════════════════════════════════════════════════ -->
    <record id="view_team_kanban" model="ir.ui.view">
        <field name="name">team.team.kanban</field>
        <field name="model">team.team</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="team_lead_id"/>
                <field name="member_count"/>
                <field name="task_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_cp_team_card">
                            <div class="o_cp_team_card_header">
                                <div class="o_cp_team_icon">
                                    <i class="fa fa-users" title="Team"/>
                                </div>
                                <div class="o_cp_team_title">
                                    <strong><field name="name"/></strong>
                                    <div class="o_cp_team_lead" t-if="record.team_lead_id.value">
                                        <i class="fa fa-star o_cp_lead_star" title="Team Lead"/>
                                        <t t-esc="record.team_lead_id.value"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_cp_team_card_footer">
                                <span class="o_cp_stat_badge o_cp_badge_members">
                                    <i class="fa fa-user" title="Members"/> <t t-esc="record.member_count.value"/> Members
                                </span>
                                <span class="o_cp_stat_badge o_cp_badge_tasks">
                                    <i class="fa fa-tasks" title="Tasks"/> <t t-esc="record.task_count.value"/> Tasks
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══ Search view ════════════════════════════════════════════════════ -->
    <record id="view_team_search" model="ir.ui.view">
        <field name="name">team.team.search</field>
        <field name="model">team.team</field>
        <field name="arch" type="xml">
            <search string="Search Teams">
                <field name="name" string="Team Name"/>
                <field name="team_lead_id" string="Team Lead"/>
                <separator/>
                <filter string="Active"   name="active"   domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Group by Team Lead" name="grp_lead"
                        context="{'group_by': 'team_lead_id'}"/>
            </search>
        </field>
    </record>

    <!-- ══ Window action ══════════════════════════════════════════════════ -->
    <record id="action_team_team" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">team.team</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_team_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first team
            </p>
            <p>
                Teams group employees together. Assign tasks within the team
                directly — cross-team assignments require manager approval.
            </p>
        </field>
    </record>

</odoo>