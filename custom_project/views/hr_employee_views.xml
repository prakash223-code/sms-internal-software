<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_team_lead" model="ir.ui.view">
        <field name="name">hr.employee.form.team.lead</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- ── Smart buttons ─────────────────────────────────────── -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">

                <!-- Teams button -->
                <button name="action_view_teams"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-users"
                        invisible="team_count == 0">
                    <field name="team_count" widget="statinfo" string="Teams"/>
                </button>

                <!-- Tasks button -->
                <button name="action_view_my_tasks"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Tasks</span>
                    </div>
                </button>

            </xpath>

            <!-- ── Team Lead badge — shown below job title when applicable ── -->
            <xpath expr="//field[@name='job_id']" position="after">

                <!-- Team Lead badge — visible to HR only -->
                <div class="o_cp_badge_team_lead"
                     invisible="not is_team_lead_of_any"
                     groups="hr.group_hr_user">
                    <i class="fa fa-star o_cp_lead_star_badge" title="Team Lead"/>
                    Team Lead
                </div>

                <!-- Teams info section — HR only -->
                <div groups="hr.group_hr_user"
                     invisible="team_count == 0">
                    <div class="o_cp_section_label">
                        <i class="fa fa-users" title="Teams"/> My Teams
                    </div>
                    <field name="team_ids"
                           widget="many2many_tags"
                           readonly="1"
                           nolabel="1"/>
                </div>

                <!-- Hidden computed fields needed for conditional rendering -->
                <field name="team_count"           invisible="1"/>
                <field name="is_team_lead_of_any"  invisible="1"/>

            </xpath>

        </field>
    </record>
</odoo>
