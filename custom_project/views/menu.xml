<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        All items hang off project.menu_main_pm (the "Project" app root).
        No custom root menu is created — our entries appear as extra
        sections inside the existing Project sidebar.

        project.menu_project_management is the core "Tasks" parent menu
        (confirmed from DB: also hides My Tasks + All Tasks children).

        Sequence guide (Project core uses ~10-40):
            50  Teams
            60  Tasks  (our replacement)
            70  Assignment Requests  (submenu)
    -->

    <!-- ══ Deactivate core Tasks menu (cascades to My Tasks + All Tasks) ══ -->
    <record id="project.menu_project_management" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ══ Teams ══════════════════════════════════════════════════════════ -->
    <menuitem id="menu_team_management_teams"
              name="Teams"
              parent="project.menu_main_pm"
              sequence="50"
              action="action_team_team"
              groups="base.group_user"/>

    <!-- ══ Tasks ═════════════════════════════════════════════════════════ -->
    <menuitem id="menu_team_management_tasks"
              name="Tasks"
              parent="project.menu_main_pm"
              sequence="60"
              groups="base.group_user"/>

    <menuitem id="menu_team_management_my_tasks"
              name="My Tasks"
              parent="menu_team_management_tasks"
              sequence="10"
              action="action_my_tasks"
              groups="base.group_user"/>

    <menuitem id="menu_team_management_all_tasks"
              name="All Tasks"
              parent="menu_team_management_tasks"
              sequence="20"
              action="action_all_tasks"
              groups="custom_project.group_team_lead"/>

    <!-- ══ Assignment Requests ════════════════════════════════════════════ -->
    <menuitem id="menu_team_management_requests"
              name="Assignment Requests"
              parent="project.menu_main_pm"
              sequence="70"
              groups="base.group_user"/>

    <menuitem id="menu_team_management_my_requests"
              name="My Requests"
              parent="menu_team_management_requests"
              sequence="10"
              action="action_my_assignment_requests"
              groups="base.group_user"/>

    <!--
        All Requests: visible to team managers AND HR users.
        Odoo evaluates comma-separated groups with OR.
    -->
    <menuitem id="menu_team_management_all_requests"
              name="All Requests"
              parent="menu_team_management_requests"
              sequence="20"
              action="action_all_assignment_requests"
              groups="custom_project.group_team_manager,hr.group_hr_user"/>

</odoo>