<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="privilege_team_management" model="res.groups.privilege">
            <field name="name">Team Management</field>
        </record>

        <record id="group_team_employee" model="res.groups">
            <field name="name">Team Project / Employee</field>
            <field name="privilege_id" ref="privilege_team_management"/>
            <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <record id="group_team_lead" model="res.groups">
            <field name="name">Team Project / Team Lead</field>
            <field name="privilege_id" ref="privilege_team_management"/>
            <field name="implied_ids" eval="[(4, ref('group_team_employee'))]"/>
        </record>

        <record id="group_team_manager" model="res.groups">
            <field name="name">Team Project / Manager</field>
            <field name="privilege_id" ref="privilege_team_management"/>
            <field name="implied_ids" eval="[
                (4, ref('group_team_lead')),
                (4, ref('project.group_project_manager'))
            ]"/>
        </record>

    </data>
</odoo>