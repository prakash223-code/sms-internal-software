<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Deactivate Odoo's built-in task visibility rules.

            project.task_visibility_rule:
              Allows ALL employees to see tasks inside projects with
              privacy_visibility='employees' — i.e. all tasks everywhere.

            project.task_visibility_rule_project_user:
              Same as above, scoped to group_project_user.

            project.ir_rule_private_task:
              Allows employees to see tasks in employees/portal projects.

            project.project_manager_all_project_tasks_rule:
              Allows project managers to see all tasks linked to any project.
              Our group_team_manager implies project.group_project_manager
              so this fires for our managers — replaced by our own rule below.
        -->
        <record id="project.task_visibility_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.task_visibility_rule_project_user" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.ir_rule_private_task" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.project_manager_all_project_tasks_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <!-- ══ task.assignment.request rules ══════════════════════════ -->

        <!--
            Regular employees: own records only
            (records where they are the requester OR the target).
        -->
        <record id="rule_assignment_request_employee" model="ir.rule">
            <field name="name">Assignment Request: own records only</field>
            <field name="model_id" ref="model_task_assignment_request"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[
                '|',
                ('requested_by.user_id', '=', user.id),
                ('target_employee_id.user_id', '=', user.id)
            ]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: all assignment requests -->
        <record id="rule_assignment_request_manager" model="ir.rule">
            <field name="name">Assignment Request: manager sees all</field>
            <field name="model_id" ref="model_task_assignment_request"/>
            <field name="groups" eval="[(4, ref('custom_project.group_team_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!--
            HR: all assignment requests.
            HR users are not in group_team_manager, so without this rule
            they fall back to the base.group_user rule and can only see
            their own records — preventing them from approving / rejecting.
        -->
        <record id="rule_assignment_request_hr" model="ir.rule">
            <field name="name">Assignment Request: HR sees all</field>
            <field name="model_id" ref="model_task_assignment_request"/>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ══ project.task rules ═════════════════════════════════════ -->

        <!--
            Employee: own team's tasks only.
            Extra OR branches ensure a cross-team approved employee can
            still see the task assigned to them, and the assigner can
            see what they created.
        -->
        <record id="rule_project_task_employee" model="ir.rule">
            <field name="name">Task: team members see own team tasks only</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">['|',
                ('team_id', '=', False),
                '|',
                ('team_id.member_ids.user_id', '=', user.id),
                '|',
                ('team_id.team_lead_id.user_id', '=', user.id),
                '|',
                ('assigned_to.user_id', '=', user.id),
                ('assigned_by.user_id', '=', user.id)
            ]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: all tasks -->
        <record id="rule_project_task_manager" model="ir.rule">
            <field name="name">Task: manager sees all</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('custom_project.group_team_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- HR: all tasks -->
        <record id="rule_project_task_hr" model="ir.rule">
            <field name="name">Task: HR sees all</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>