<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_task_assignment_request" model="ir.sequence">
            <field name="name">Task Assignment Request</field>
            <field name="code">task.assignment.request</field>
            <field name="prefix">TAR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_project_completion_request" model="ir.sequence">
            <field name="name">Project Completion Request</field>
            <field name="code">project.completion.request</field>
            <field name="prefix">PCR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_project_project" model="ir.sequence">
            <field name="name">Project Reference</field>
            <field name="code">project.project.code</field>
            <field name="prefix">PRJ</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>