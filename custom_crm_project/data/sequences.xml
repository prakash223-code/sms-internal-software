<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Project number sequence.
            Produces: 001, 002, 003, …
            noupdate="1" ensures it is never reset on module upgrade.
        -->
        <record id="seq_project_number" model="ir.sequence">
            <field name="name">Project Number</field>
            <field name="code">custom.project.number</field>
            <field name="prefix"></field>
            <field name="suffix"></field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>
    </data>
</odoo>
