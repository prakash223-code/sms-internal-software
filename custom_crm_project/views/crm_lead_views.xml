<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_view_form_convert" model="ir.ui.view">
        <field name="name">crm.lead.form.convert.project</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- 1. Convert button -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_convert_to_project"
                    string="Convert to Project"
                    type="object"
                    class="btn-primary"
                    invisible="is_converted"
                    groups="hr.group_hr_user"
                    confirm="Are you sure you want to convert this Won opportunity into a project? This action cannot be undone."
                />
            </xpath>

            <!-- 2. Converted banner -->
            <xpath expr="//sheet" position="before">
                <div class="o_crm_banner o_crm_banner_confirmed"
                     invisible="not is_converted">
                    <i class="fa fa-check-circle" title="Converted to Project"/>
                    This opportunity has been <strong>converted to a project</strong>
                    and is now read-only.
                </div>
            </xpath>

            <!-- 3. Section label — Opportunity Details -->
            <xpath expr="//sheet" position="inside">
                <div class="o_crm_section_label">Opportunity Details</div>
            </xpath>

            <!-- 4. Section label — Revenue & Forecast
                 Injected before expected_revenue field group -->
            <xpath expr="//field[@name='expected_revenue']" position="before">
                <div class="o_crm_section_label">Revenue &amp; Forecast</div>
            </xpath>

            <!-- 5. Smart button — project link -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    name="action_open_linked_project"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-folder-open"
                    invisible="not is_converted">
                    <div class="o_field_widget o_stat_info">
                        <div class="o_stat_value">
                            <field name="project_count"/>
                        </div>
                        <div class="o_stat_text">Project</div>
                    </div>
                </button>
            </xpath>

            <!-- 6. Hidden fields -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_converted" invisible="1"/>
            </xpath>

            <!-- 7. Read-only locks -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='team_id']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='expected_revenue']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>
            <xpath expr="//field[@name='probability']" position="attributes">
                <attribute name="readonly">is_converted</attribute>
            </xpath>

        </field>
    </record>

</odoo>