<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ================================================================
       FORM VIEW
       ================================================================ -->
  <record id="view_hr_employee_document_form" model="ir.ui.view">
    <field name="name">hr.employee.document.form</field>
    <field name="model">hr.employee.document</field>
    <field name="arch" type="xml">
      <form string="Employee Document">
        <sheet>
          <group>
            <group string="Document Details">
              <field name="name"
                     string="Document Name"
                     placeholder="e.g. Aadhar Card, Offer Letter"/>
              <field name="document_type"/>
              <field name="employee_id" readonly="1"/>
            </group>
            <group string="Upload Info">
              <field name="file_type" readonly="1"/>
              <field name="upload_date" readonly="1"/>
              <field name="uploaded_by" readonly="1"/>
            </group>
          </group>

          <group string="File">
            <field name="file"
                   filename="filename"
                   string="Attach File"
                   widget="binary"/>
            <field name="filename" invisible="1"/>
            <field name="file_url"
                   string="Preview in Browser"
                   widget="url"
                   text="Click to Preview"
                   invisible="not file_url"
                   readonly="1"/>
          </group>

          <group string="Notes">
            <field name="notes"
                   string=""
                   placeholder="Optional remarks about this document..."/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ================================================================
       LIST VIEW — standalone (opened via smart button)
       ================================================================ -->
  <record id="view_hr_employee_document_list" model="ir.ui.view">
    <field name="name">hr.employee.document.list</field>
    <field name="model">hr.employee.document</field>
    <field name="arch" type="xml">
      <list string="Documents"
            create="1"
            delete="1">

        <field name="name"
               string="Document Name"/>

        <field name="document_type"
               string="Category"/>

        <!-- File extension column: PDF, PNG, DOCX etc -->
        <field name="file_type"
               string="File Type"
               readonly="1"/>

        <field name="file"
               filename="filename"
               string="File"
               widget="binary"/>

        <field name="filename"
               string="File Name"
               readonly="1"/>

        <field name="file_url"
               string="Preview"
               widget="url"
               text="Preview"
               invisible="not file_url"
               readonly="1"/>

        <field name="upload_date"
               string="Uploaded On"
               readonly="1"/>

        <field name="uploaded_by"
               string="Uploaded By"
               readonly="1"/>

        <field name="notes"
               string="Notes"
               optional="show"/>

      </list>
    </field>
  </record>

  <!-- ================================================================
       ACTION
       ================================================================ -->
  <record id="action_hr_employee_document" model="ir.actions.act_window">
    <field name="name">Employee Documents</field>
    <field name="res_model">hr.employee.document</field>
    <field name="view_mode">list,form</field>
    <field name="context">{'default_employee_id': active_id}</field>
  </record>

</odoo>