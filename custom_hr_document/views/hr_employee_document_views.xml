<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         FORM VIEW
         ================================================================ -->
    <record id="view_hr_employee_document_form" model="ir.ui.view">
        <field name="name">hr.employee.document.form</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <form string="Employee Document">

                <!-- Banners — before <sheet> so they span full width on all viewports -->
                <div class="o_hrd_banner o_hrd_banner_info" invisible="filename">
                    <i class="fa fa-cloud-upload" title="Upload Required"/>
                    <div>
                        <strong>No file yet</strong>
                        — attach a document file below to complete this record.
                    </div>
                </div>
                <div class="o_hrd_banner o_hrd_banner_success" invisible="not filename">
                    <i class="fa fa-check-circle" title="File Uploaded"/>
                    <div>
                        <strong>File attached</strong>
                        — use the Preview link below to open it in your browser.
                    </div>
                </div>

                <sheet>

                    <!-- Reference block — uses flex + max-width so it scales on every screen -->
                    <div class="oe_title">
                        <div class="o_hrd_ref_block">
                            <div class="o_hrd_ref_icon">
                                <i class="fa fa-file-text" title="Document"/>
                            </div>
                            <div class="o_hrd_ref_text_group">
                                <div class="o_hrd_ref_label">Document Name</div>
                                <div class="o_hrd_ref_value">
                                    <field name="name" nolabel="1" placeholder="e.g. Aadhar Card, Offer Letter"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Document Details -->
                    <div class="o_hrd_section_label">
                        <i class="fa fa-info-circle" title="Details"/>
                        Document Details
                    </div>
                    <div class="o_hrd_info_card">
                        <!-- Two nested groups → Odoo stacks them on narrow viewports automatically -->
                        <group>
                            <group>
                                <field name="employee_id" readonly="1"/>
                                <field name="document_type"/>
                            </group>
                            <group>
                                <field name="upload_date" readonly="1"/>
                                <field name="uploaded_by" readonly="1"/>
                            </group>
                        </group>
                    </div>

                    <div class="o_hrd_divider"/>

                    <!-- File upload -->
                    <div class="o_hrd_section_label">
                        <i class="fa fa-paperclip" title="File"/>
                        Attached File
                    </div>
                    <div class="o_hrd_file_card">
                        <group>
                            <field name="file" filename="filename" string="Attach File" widget="binary"/>
                            <field name="filename" invisible="1"/>
                            <!-- File type badge — shown after a file is uploaded -->
                            <div invisible="not file_type or file_type == '—'" style="padding:2px 0 4px 0;">
                                <span class="o_hrd_filetype_badge">
                                    <i class="fa fa-file-o" title="Type"/>
                                    <field name="file_type" readonly="1" nolabel="1"/>
                                </span>
                            </div>
                            <!-- Preview link -->
                            <field name="file_url" string="Preview in Browser" widget="url"
                                   text="Click to Preview" invisible="not file_url" readonly="1"/>
                        </group>
                    </div>

                    <div class="o_hrd_divider"/>

                    <!-- Notes -->
                    <div class="o_hrd_section_label">
                        <i class="fa fa-sticky-note-o" title="Notes"/>
                        Notes
                    </div>
                    <group>
                        <field name="notes" string="" nolabel="1"
                               placeholder="Optional remarks about this document..."/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <!-- ================================================================
         LIST VIEW
         ================================================================ -->
    <record id="view_hr_employee_document_list" model="ir.ui.view">
        <field name="name">hr.employee.document.list</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <list string="Documents" create="1" delete="1"
                  decoration-info="document_type == 'id_proof'"
                  decoration-success="document_type in ('educational', 'contract')"
                  decoration-warning="document_type == 'experience'"
                  decoration-danger="document_type == 'medical'">

                <!-- Always-visible columns — minimal set that fits on mobile -->
                <field name="name" string="Document Name"/>
                <field name="document_type" string="Category" widget="badge"
                       decoration-info="document_type == 'id_proof'"
                       decoration-success="document_type in ('educational', 'contract')"
                       decoration-warning="document_type == 'experience'"
                       decoration-danger="document_type == 'medical'"/>

                <!-- optional columns collapse on narrow screens via Odoo list widget -->
                <field name="file_type" string="Type" readonly="1" optional="show"/>
                <field name="employee_id" string="Employee" optional="show"/>
                <field name="file" filename="filename" string="File"
                       widget="binary" optional="show"/>
                <field name="filename" string="File Name" readonly="1" optional="hide"/>
                <field name="file_url" string="Preview" widget="url"
                       text="Preview" invisible="not file_url" readonly="1" optional="show"/>
                <field name="upload_date" string="Uploaded On" readonly="1" optional="show"/>
                <field name="uploaded_by" string="Uploaded By" readonly="1" optional="hide"/>
                <field name="notes" string="Notes" optional="hide"/>

            </list>
        </field>
    </record>


    <!-- ================================================================
         KANBAN VIEW
         ================================================================ -->
    <record id="view_hr_employee_document_kanban" model="ir.ui.view">
        <field name="name">hr.employee.document.kanban</field>
        <field name="model">hr.employee.document</field>
        <field name="arch" type="xml">
            <kanban default_group_by="document_type" quick_create="false"
                    class="o_hrd_kanban_view">

                <field name="name"/>
                <field name="document_type"/>
                <field name="file_type"/>
                <field name="employee_id"/>
                <field name="upload_date"/>
                <field name="uploaded_by"/>
                <field name="file_url"/>
                <field name="filename"/>

                <templates>
                    <t t-name="card">

                        <!-- ── Header: coloured file-type icon + title + badge ── -->
                        <div class="o_hrd_card_header">

                            <!-- File-type icon: colour and FA icon chosen by extension -->
                            <t t-set="ft"
                               t-value="record.file_type.raw_value ? record.file_type.raw_value.toUpperCase() : ''"/>
                            <div t-attf-class="o_hrd_doc_icon #{
                  ft == 'PDF'  ? 'o_hrd_icon_pdf'   :
                  ft == 'DOC' or ft == 'DOCX' ? 'o_hrd_icon_word'  :
                  ft == 'XLS' or ft == 'XLSX' ? 'o_hrd_icon_excel' :
                  ft == 'PNG' or ft == 'JPG' or ft == 'JPEG' or ft == 'GIF' or ft == 'WEBP' or ft == 'SVG' ? 'o_hrd_icon_image' :
                  ft == 'PPT' or ft == 'PPTX' ? 'o_hrd_icon_ppt'   :
                  ft == 'ZIP' or ft == 'RAR'  or ft == '7Z' ? 'o_hrd_icon_zip'   :
                  ft == 'TXT' ? 'o_hrd_icon_txt'   :
                  'o_hrd_icon_other'
              }">
                                <i t-attf-class="fa #{
                    ft == 'PDF'  ? 'fa-file-pdf-o'        :
                    ft == 'DOC' or ft == 'DOCX' ? 'fa-file-word-o'       :
                    ft == 'XLS' or ft == 'XLSX' ? 'fa-file-excel-o'      :
                    ft == 'PNG' or ft == 'JPG' or ft == 'JPEG' or ft == 'GIF' or ft == 'WEBP' or ft == 'SVG' ? 'fa-file-image-o' :
                    ft == 'PPT' or ft == 'PPTX' ? 'fa-file-powerpoint-o' :
                    ft == 'ZIP' or ft == 'RAR'  or ft == '7Z' ? 'fa-file-archive-o' :
                    ft == 'TXT' ? 'fa-file-text-o'        :
                    'fa-file-o'
                }" t-att-title="ft or 'File'"/>
                                <t t-if="ft">
                                    <span class="o_hrd_doc_icon_ext">
                                        <t t-esc="ft"/>
                                    </span>
                                </t>
                            </div>

                            <!-- Title column: document name + type badge -->
                            <div class="o_hrd_card_title">
                                <div class="o_hrd_card_name">
                                    <field name="name"/>
                                </div>
                                <field name="document_type" widget="badge"
                                       decoration-info="document_type == 'id_proof'"
                                       decoration-success="document_type in ('educational', 'contract')"
                                       decoration-warning="document_type == 'experience'"
                                       decoration-danger="document_type == 'medical'"/>
                            </div>
                        </div>

                        <div class="o_hrd_kanban_divider"/>

                        <!-- ── Meta: employee + upload date ─────────────────── -->
                        <div class="o_hrd_card_meta">
                            <div class="o_hrd_card_meta_row">
                                <i class="fa fa-user-o" title="Employee"/>
                                <field name="employee_id"/>
                            </div>
                            <div class="o_hrd_card_meta_row">
                                <i class="fa fa-calendar-o" title="Upload Date"/>
                                <field name="upload_date"/>
                                <t t-if="record.uploaded_by.raw_value">
                                    <span class="o_hrd_card_meta_sep">·</span>
                                    <field name="uploaded_by"/>
                                </t>
                            </div>
                        </div>

                        <div class="o_hrd_kanban_divider"/>

                        <!-- ── Footer: preview or no-file pill ──────────────── -->
                        <div class="o_hrd_card_footer">
                            <t t-if="record.file_url.raw_value">
                                <a class="o_hrd_preview_btn"
                                   role="button"
                                   t-att-href="record.file_url.raw_value"
                                   target="_blank"
                                   onclick="event.stopPropagation()">
                                    <i class="fa fa-eye" title="Preview"/>
                                    Preview File
                                </a>
                            </t>
                            <t t-else="">
                                <div class="o_hrd_nofile_btn">
                                    <i class="fa fa-cloud-upload" title="No File"/>
                                    No file attached
                                </div>
                            </t>
                        </div>

                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- ================================================================
         ACTION
         ================================================================ -->
    <record id="action_hr_employee_document" model="ir.actions.act_window">
        <field name="name">Employee Documents</field>
        <field name="res_model">hr.employee.document</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'default_employee_id': active_id}</field>
    </record>

</odoo>