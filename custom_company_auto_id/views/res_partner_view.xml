<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_company_id_form" model="ir.ui.view">
        <field name="name">res.partner.company.id.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Register our custom JS controller -->
            <xpath expr="//form" position="attributes">
                <attribute name="js_class">res_partner_company_id_form</attribute>
            </xpath>

            <!-- Country is mandatory for companies (client-side) -->
            <field name="country_id" position="attributes">
                <attribute name="required">is_company</attribute>
            </field>

            <!-- Company ID display (read-only, auto-generated) -->
            <field name="name" position="after">
                <field name="company_custom_id"
                       string="Company ID"
                       readonly="1"
                       invisible="not is_company"/>
                <!--
                    Fallback button: only visible when a company has no ID yet
                    (e.g. an existing contact converted to a company, or a
                    record created before this module was installed).
                -->
                <button string="Generate Company ID"
                        name="action_generate_company_id"
                        type="object"
                        class="btn-secondary"
                        invisible="not is_company or company_custom_id"/>
            </field>

            <!-- Show parent company's ID on individual contacts -->
            <field name="parent_id" position="after">
                <field name="contact_company_id_display"
                       string="Company ID"
                       readonly="1"
                       invisible="is_company or not parent_id"/>
            </field>

        </field>
    </record>

    <record id="view_partner_company_id_search" model="ir.ui.view">
        <field name="name">res.partner.company.id.search</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_custom_id" string="Company ID"/>
            </field>
        </field>
    </record>
</odoo>