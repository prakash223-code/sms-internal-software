<odoo>
    <record id="crm_lead_company_id_view" model="ir.ui.view">
        <field name="name">crm.lead.form.company.id</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <!-- For OPPORTUNITY -->
            <xpath expr="//group[@name='opportunity_partner']//field[@name='partner_id']" position="after">
                <field name="partner_company_id_display"
                       string="Auto Company ID"
                       widget="badge"
                       readonly="1"/>
            </xpath>

            <!-- For LEAD -->
            <xpath expr="//group[@name='lead_partner']//field[@name='partner_id']" position="after">
                <field name="partner_company_id_display"
                       string="Auto Company ID"
                       widget="badge"
                       readonly="1"/>
            </xpath>

        </field>
    </record>
</odoo>