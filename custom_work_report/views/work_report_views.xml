<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence -->
    <record id="seq_work_report" model="ir.sequence">
        <field name="name">Work Report Sequence</field>
        <field name="code">work.report.seq</field>
        <field name="prefix">WR/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
    </record>

    <!-- List view -->
    <record id="view_work_report_list" model="ir.ui.view">
        <field name="name">work.report.list</field>
        <field name="model">work.report</field>
        <field name="arch" type="xml">
            <list string="Work Reports"
                  decoration-muted="state == 'draft'"
                  decoration-success="state == 'submitted'">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="hours_spent"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'submitted'"/>
            </list>
        </field>
    </record>

    <!-- kanban view -->
    <record id="view_work_report_kanban" model="ir.ui.view">
        <field name="name">work.report.kanban</field>
        <field name="model">work.report</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">

                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="hours_spent"/>
                <field name="state"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card p-3">

                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>

                            <div class="text-muted">
                                <field name="date"/>
                            </div>

                            <div class="mt-2">
                                <strong>Employee:</strong>
                                <field name="employee_id"/>
                            </div>

                            <div>
                                <strong>Project:</strong>
                                <field name="project_id"/>
                            </div>

                            <div>
                                <strong>Hours:</strong>
                                <field name="hours_spent"/>
                            </div>

                            <div class="mt-2">
                                <field name="state"
                                       widget="badge"
                                       decoration-warning="state == 'draft'"
                                       decoration-success="state == 'submitted'"/>
                            </div>

                        </div>
                    </t>
                </templates>

            </kanban>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_work_report_form" model="ir.ui.view">
        <field name="name">work.report.form</field>
        <field name="model">work.report</field>
        <field name="arch" type="xml">
            <form string="Daily Work Report">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'submitted'"
                            groups="custom_work_report.group_work_report_hr"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="hours_spent"/>
                        </group>
                    </group>
                    <group string="Work Done">
                        <field name="description"
                               nolabel="1"
                               placeholder="Describe what was accomplished today..."/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids"
                               widget="attachment_preview"
                               nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_work_report_search" model="ir.ui.view">
        <field name="name">work.report.search</field>
        <field name="model">work.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id" readonly="1"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="submitted"
                        domain="[('state','=','submitted')]"/>
                <separator/>
                <filter string="Group by Employee" name="by_employee"
                        context="{'group_by': 'employee_id'}"/>
                <filter string="Group by Project" name="by_project"
                        context="{'group_by': 'project_id'}"/>
                <filter string="Group by Month" name="by_month"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action for employees - filtered to own records -->
    <record id="action_work_report_employee" model="ir.actions.act_window">
        <field name="name">My Work Reports</field>
        <field name="res_model">work.report</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
    </record>

    <!-- Action for Manager - all records -->
    <record id="action_work_report_all" model="ir.actions.act_window">
        <field name="name">All Work Reports</field>
        <field name="res_model">work.report</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_work_report_root"
              name="Work Reports"
              sequence="50"
              web_icon="custom_work_report,static/description/icon.png"/>

    <menuitem id="menu_work_report_my"
              name="My Reports"
              parent="menu_work_report_root"
              action="action_work_report_employee"
              groups="custom_work_report.group_work_report_employee"
              sequence="1"/>

    <menuitem id="menu_work_report_all"
              name="All Reports"
              parent="menu_work_report_root"
              action="action_work_report_all"
              groups="custom_work_report.group_work_report_hr"
              sequence="2"/>

</odoo>