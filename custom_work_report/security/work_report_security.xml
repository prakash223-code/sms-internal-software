<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="group_work_report_employee" model="res.groups">
      <field name="name">Work Report: Employee</field>
    </record>

    <record id="group_work_report_hr" model="res.groups">
      <field name="name">Work Report: HR</field>
    </record>

    <record id="group_work_report_manager" model="res.groups">
      <field name="name">Work Report: Manager</field>
    </record>

    <!-- All internal users get employee group -->
    <record id="base.group_user" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('group_work_report_employee'))]"/>
    </record>

    <record id="hr.group_hr_user" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('group_work_report_hr'))]"/>
    </record>

    <record id="hr.group_hr_manager" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('group_work_report_manager'))]"/>
    </record>

    <!--
      IMPORTANT: Rules are OR'd per group, but AND'd across groups.
      To avoid HR (who implies Employee) being blocked by the
      employee-own rule, we scope the own-only rule STRICTLY
      to employee group and give HR/Manager unrestricted rules.
    -->

    <!-- Plain employees: own records only -->
    <record id="rule_work_report_employee_own" model="ir.rule">
      <field name="name">Work Report: Employee sees own only</field>
      <field name="model_id" ref="model_work_report"/>
      <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_work_report_employee'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- HR: sees all (overrides employee rule for HR users) -->
    <record id="rule_work_report_hr_all" model="ir.rule">
      <field name="name">Work Report: HR sees all</field>
      <field name="model_id" ref="model_work_report"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('group_work_report_hr'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Manager: sees all -->
    <record id="rule_work_report_manager_all" model="ir.rule">
      <field name="name">Work Report: Manager sees all</field>
      <field name="model_id" ref="model_work_report"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('group_work_report_manager'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="True"/>
    </record>

  </data>
</odoo>