<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_mrp_bom" model="ir.sequence">
            <field name="name">BOM Reference</field>
            <field name="code">custom.mrp.bom</field>
            <field name="prefix">BOM</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_mrp_production" model="ir.sequence">
            <field name="name">Production Reference</field>
            <field name="code">custom.mrp.production</field>
            <field name="prefix">PRD</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_mrp_serial" model="ir.sequence">
            <field name="name">Product Serial Number</field>
            <field name="code">custom.mrp.serial</field>
            <field name="prefix">SN</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>