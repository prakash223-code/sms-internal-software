<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_actions_server_warranty_expiry" model="ir.actions.server">
            <field name="name">Send Warranty Expiry Alerts</field>
            <field name="model_id" ref="custom_manufacturing.model_mrp_warranty"/>
            <field name="state">code</field>
            <field name="code">model.action_send_expiry_alerts()</field>
        </record>

        <record id="ir_cron_warranty_expiry_alert" model="ir.cron">
            <field name="name">Warranty Expiry Alert</field>
            <field name="ir_actions_server_id" ref="ir_actions_server_warranty_expiry"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>