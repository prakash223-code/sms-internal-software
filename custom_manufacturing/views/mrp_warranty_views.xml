<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         LIST VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_mrp_warranty_list" model="ir.ui.view">
        <field name="name">mrp.warranty.list</field>
        <field name="model">mrp.warranty</field>
        <field name="arch" type="xml">
            <list decoration-danger="warranty_status == 'expired'"
                  decoration-warning="warranty_status == 'expiring'"
                  decoration-success="warranty_status == 'active'">
                <field name="serial_number"   string="Serial No"/>
                <field name="product_id"      string="Product"/>
                <field name="client_id"       string="Client"/>
                <field name="production_id"   string="Manufacturing Order"/>
                <field name="warranty_start"  string="Start"/>
                <field name="warranty_end"    string="End"/>
                <field name="warranty_years"  string="Years"/>
                <field name="days_remaining"  string="Days Left"/>
                <field name="warranty_status" string="Status"
                       widget="badge"
                       decoration-success="warranty_status == 'active'"
                       decoration-warning="warranty_status == 'expiring'"
                       decoration-danger="warranty_status == 'expired'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_mrp_warranty_form" model="ir.ui.view">
        <field name="name">mrp.warranty.form</field>
        <field name="model">mrp.warranty</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_print_warranty_certificate"
                            string="Print Certificate"
                            type="object"
                            icon="fa-print"
                            class="btn-primary"/>
                    <field name="warranty_status"
                           widget="statusbar"
                           statusbar_visible="active,expiring,expired"
                           readonly="1"/>
                </header>
                <sheet>
                    <group>
                        <group string="Product Info">
                            <field name="serial_number" readonly="1"/>
                            <field name="product_id"/>
                            <field name="client_id"/>
                            <field name="production_id"/>
                        </group>
                        <group string="Warranty Period">
                            <field name="warranty_start"/>
                            <field name="warranty_end"/>
                            <field name="warranty_years"/>
                            <field name="days_remaining" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Warranty notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

