    <!-- ══════════════════════════════════════════════════════
         WINDOW ACTIONS
    ══════════════════════════════════════════════════════════ -->
    <record id="action_mrp_warranty" model="ir.actions.act_window">
        <field name="name">Warranties</field>
        <field name="res_model">mrp.warranty</field>
        <field name="view_mode">list,form</field>
        <!--field name="search_view_id" ref="view_mrp_warranty_search"/-->
    </record>

    <record id="action_mrp_warranty_active" model="ir.actions.act_window">
        <field name="name">Active Warranties</field>
        <field name="res_model">mrp.warranty</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('warranty_status','=','active')]</field>
        <!--field name="search_view_id" ref="view_mrp_warranty_search"/-->
    </record>

    <record id="action_mrp_warranty_expiring" model="ir.actions.act_window">
        <field name="name">Expiring Warranties</field>
        <field name="res_model">mrp.warranty</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('warranty_status','=','expiring')]</field>
        <!--field name="search_view_id" ref="view_mrp_warranty_search"/-->
    </record>

    <record id="action_mrp_assembly" model="ir.actions.act_window">
        <field name="name">Assembly Orders</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('manufacturing_type','in',['assembly','both'])]</field>
    </record>

    <record id="action_mrp_production_orders" model="ir.actions.act_window">
        <field name="name">Production Orders</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('manufacturing_type','in',['production','both'])]</field>
    </record>

</odoo>