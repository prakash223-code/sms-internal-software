<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_mrp_custom_user" model="res.groups">
        <field name="name">Manufacturing Custom User</field>
        <field name="implied_ids" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>

    <record id="group_mrp_custom_manager" model="res.groups">
        <field name="name">Manufacturing Custom Manager</field>

        <field name="implied_ids" eval="[
            (4, ref('mrp.group_mrp_manager')),
            (4, ref('custom_manufacturing.group_mrp_custom_user'))
        ]"/>
    </record>

</odoo>