<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_mrp_job_card" model="ir.actions.report">
        <field name="name">Job Card</field>
        <field name="model">mrp.production</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_manufacturing.report_mrp_job_card</field>
        <field name="report_file">custom_manufacturing.report_mrp_job_card</field>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_mrp_job_card">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2>Job Card — <span t-field="o.custom_production_ref"/></h2>

                        <div class="row mt16 mb8">
                            <div class="col-6">
                                <strong>Manufacturing Order:</strong>
                                <span t-field="o.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Type:</strong>
                                <span t-field="o.manufacturing_type"/>
                            </div>
                        </div>

                        <div class="row mb8">
                            <div class="col-6">
                                <strong>Product:</strong>
                                <span t-field="o.product_id.display_name"/>
                            </div>
                            <div class="col-6">
                                <strong>Quantity:</strong>
                                <span t-field="o.product_qty"/>
                                <span t-field="o.product_uom_id"/>
                            </div>
                        </div>

                        <div class="row mb8">
                            <div class="col-6">
                                <strong>Client:</strong>
                                <span t-field="o.client_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Component Status:</strong>
                                <span t-field="o.component_status"/>
                            </div>
                        </div>

                        <h4 class="mt16">Components</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Component</th>
                                    <th>Type</th>
                                    <th>Required Qty</th>
                                    <th>Available Qty</th>
                                    <th>Critical</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.move_raw_ids" t-as="line">
                                    <tr t-att-class="'table-danger' if line.quantity &lt; line.product_uom_qty else ''">
                                        <td><span t-field="line.product_id.display_name"/></td>
                                        <td>
                                            <t t-if="line.bom_line_id">
                                                <span t-field="line.bom_line_id.component_type"/>
                                            </t>
                                        </td>
                                        <td><span t-field="line.product_uom_qty"/></td>
                                        <td><span t-field="line.quantity"/></td>
                                        <td>
                                            <t t-if="line.bom_line_id and line.bom_line_id.is_critical">
                                                ✓
                                            </t>
                                        </td>
                                        <td>
                                            <t t-if="line.bom_line_id">
                                                <span t-field="line.bom_line_id.component_notes"/>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="o.assembly_notes or o.production_notes">
                            <h4 class="mt16">Instructions</h4>
                            <t t-if="o.assembly_notes">
                                <p><strong>Assembly:</strong></p>
                                <p t-field="o.assembly_notes"/>
                            </t>
                            <t t-if="o.production_notes">
                                <p><strong>Production:</strong></p>
                                <p t-field="o.production_notes"/>
                            </t>
                        </t>

                        <h4 class="mt16">Cost Summary</h4>
                        <table class="table table-sm" style="max-width: 400px;">
                            <tr>
                                <td>Component Cost</td>
                                <td class="text-end">
                                    ₹ <span t-field="o.total_component_cost"
                                            t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                            <tr>
                                <td>Labour Cost</td>
                                <td class="text-end">
                                    ₹ <span t-field="o.labour_cost"
                                            t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                            <tr>
                                <td>Overhead Cost</td>
                                <td class="text-end">
                                    ₹ <span t-field="o.overhead_cost"
                                            t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Total Cost</td>
                                <td class="text-end">
                                    ₹ <span t-field="o.total_production_cost"
                                            t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                        </table>

                        <t t-if="o.serial_number_ids">
                            <h4 class="mt16">Serial Numbers</h4>
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Serial No</th>
                                        <th>Client</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.serial_number_ids" t-as="sn">
                                        <tr>
                                            <td><t t-out="sn_index + 1"/></td>
                                            <td><span t-field="sn.serial_number"/></td>
                                            <td><span t-field="sn.client_id.name"/></td>
                                            <td><span t-field="sn.notes"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <div class="row mt32">
                            <div class="col-4 text-center">
                                <p>___________________________</p>
                                <p>Prepared By</p>
                            </div>
                            <div class="col-4 text-center">
                                <p>___________________________</p>
                                <p>Quality Check</p>
                            </div>
                            <div class="col-4 text-center">
                                <p>___________________________</p>
                                <p>Approved By</p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>