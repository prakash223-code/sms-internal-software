<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_serial_wizard_form" model="ir.ui.view">
        <field name="name">mrp.serial.wizard.form</field>
        <field name="model">mrp.serial.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Serial Numbers &amp; Warranties">
                <group>
                    <group string="Order">
                        <field name="production_id" readonly="1"/>
                        <field name="client_id"/>
                    </group>
                    <group string="Generation Parameters">
                        <field name="qty" string="Quantity"/>
                        <field name="warranty_years"/>
                        <field name="warranty_start"/>
                    </group>
                </group>

                <separator string="Preview — serial numbers to be created"/>
                <field name="line_ids" readonly="1">
                    <list>
                        <field name="serial_number" string="Serial No"/>
                        <field name="product_id" string="Product"/>
                        <field name="client_id" string="Client"/>
                        <field name="notes" string="Notes"/>
                    </list>
                </field>

                <footer>
                    <button name="action_generate"
                            string="Generate Preview"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_confirm"
                            string="Confirm &amp; Create"
                            type="object"
                            class="btn-primary"
                            confirm="This will create serial numbers and warranties. Continue?"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mrp_serial_wizard" model="ir.actions.act_window">
        <field name="name">Generate Serial Numbers</field>
        <field name="res_model">mrp.serial.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>