<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Record Rule: Employee sees own payslips only ──────────────────────
         Applies to base employee group only.
         HR and Manager are in hr_user / hr_manager groups — exempt.
    ──────────────────────────────────────────────────────────────────────── -->

    <record id="payslip_line_employee_rule" model="ir.rule">
        <field name="name">Payslip Line: Employee sees own records only</field>
        <field name="model_id" ref="bi_hr_payroll.model_hr_payslip_line"/>
        <field name="domain_force">
            [('slip_id.employee_id.user_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <!-- Explicitly exclude HR and Manager from this rule -->
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- HR sees all payslip lines -->
    <record id="payslip_line_hr_rule" model="ir.rule">
        <field name="name">Payslip Line: HR sees all</field>
        <field name="model_id" ref="bi_hr_payroll.model_hr_payslip_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <!-- Manager sees all payslip lines -->
    <record id="payslip_line_manager_rule" model="ir.rule">
        <field name="name">Payslip Line: Manager sees all</field>
        <field name="model_id" ref="bi_hr_payroll.model_hr_payslip_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
    </record>

    <!-- Allow employees to read their own bank accounts for payslip report -->
    <record id="partner_bank_employee_rule" model="ir.rule">
        <field name="name">Partner Bank: Employee sees own records</field>
        <field name="model_id" ref="base.model_res_partner_bank"/>
        <field name="domain_force">
            [('partner_id', '=', user.partner_id.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>