<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_simple_form_password" model="ir.ui.view">
        <field name="name">res.users.simple.form.password</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_simple_form"/>
        <field name="arch" type="xml">
            <!-- Target the parent div of login field, insert password div after it -->
            <xpath expr="//field[@name='login']/.." position="after">
                <div class="d-flex align-items-baseline w-100">
                    <i class="fa fa-fw me-1 fa-lock text-primary" title="Password"/>
                    <field name="password"
                           class="w-100"
                           password="True"
                           placeholder="Password (leave blank to send reset email)"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>