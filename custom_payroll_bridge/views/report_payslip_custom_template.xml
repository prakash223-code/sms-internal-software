<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         Overrides bi_hr_payroll's default payslip print format with
         SMS Enterprises' official layout — FULL bypass of
         web.external_layout.

         NOTE 1: Bootstrap utility classes do NOT reliably apply in this
         bypassed-layout context. All visual styling uses explicit
         inline style= attributes instead.

         NOTE 2: page margins (the physical PDF margin) are controlled
         separately via data/payslip_paperformat.xml.

         NOTE 3: header uses position:absolute (a new technique vs the
         table-based layout used elsewhere in this file) — needed so
         "PAYSLIP" can sit centered across the FULL page width while
         occupying the same horizontal band as the logo, vertically
         aligned against the logo's "ENTERPRISES" text line. The
         top:140px offset on the PAYSLIP heading is an ESTIMATE based
         on typical logo proportions, not a measurement of the actual
         logo file — adjust this single value if it doesn't land
         exactly on the "ENTERPRISES" line once printed.
    ══════════════════════════════════════════════════════════════════════ -->
    <template id="report_payslip_sms_format" inherit_id="bi_hr_payroll.report_payslip">

        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <div class="page" style="font-family: Arial, Helvetica, sans-serif; font-size: 16px; padding: 0px 25px 15px 25px !important; margin: 0 !important; min-height: 0 !important;">

                <meta charset="utf-8"/>

                <!-- ── Header band: logo top-right, "PAYSLIP" centered
                     across the full width, vertically aligned against
                     the logo's "ENTERPRISES" line via absolute top
                     offset. Container height matches logo max-height
                     so the two never overlap unexpectedly. ──────────── -->
                <div style="position:relative; width:100%; height:220px; margin-bottom:8px;">
                    <img t-if="o.company_id.logo"
                         t-att-src="image_data_uri(o.company_id.logo)"
                         style="position:absolute; top:0; right:0; display:block; max-height:220px; max-width:35%;"/>
                    <h2 style="position:absolute; top:140px; left:0; right:0; margin:0; text-align:center; font-weight:bold; letter-spacing:1px; font-size:32px;">
                        PAYSLIP
                    </h2>
                </div>

                <!-- ── Company name + Address — full-width centered ──────── -->
                <h4 style="text-align:center; font-weight:bold; font-size:18px; margin:0 0 6px 0;">
                    <span t-esc="(o.company_id.name or '').upper()"/>
                </h4>
                <p style="text-align:center; font-size:14px; margin:0 0 24px 0;">
                    <span t-esc="o.company_id.street"/>
                    <t t-if="o.company_id.street2">, <span t-esc="o.company_id.street2"/></t>,
                    <span t-esc="o.company_id.city"/>
                    - <span t-esc="o.company_id.zip"/>,
                    <span t-esc="o.company_id.state_id.name"/>,
                    <span t-esc="o.company_id.country_id.name"/>.
                </p>

                <!-- ── Info block: borderless, colon-style rows ──────────── -->
                <table style="width:100%; border:none; font-size:16px; margin-bottom: 24px;">
                    <tr>
                        <td style="border:none; width:50%; padding:4px 0;">
                            <strong>Pay Date</strong> :
                            <span t-if="o.confirmed_date" t-field="o.confirmed_date"/>
                            <span t-else="">—</span>
                        </td>
                        <td style="border:none; width:50%; padding:4px 0;">
                            <strong>Employee Name</strong> :
                            <span t-field="o.employee_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="border:none; padding:4px 0;">
                            <strong>Pay Period</strong> :
                            <span t-esc="o._get_pay_period_label()"/>
                        </td>
                        <td style="border:none; padding:4px 0;">
                            <strong>Employee ID</strong> :
                            <span t-field="o.employee_id.employee_code"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="border:none; padding:4px 0;">
                            <strong>No. of Present</strong> :
                            <span t-if="o.attendance_summary_id" t-field="o.attendance_summary_id.present_days"/>
                            <span t-else="">—</span>
                        </td>
                        <td style="border:none; padding:4px 0;">
                            <strong>Designation</strong> :
                            <span t-field="o.employee_id.job_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="border:none; padding:4px 0;">
                            <strong>Working Days</strong> :
                            <span t-if="o.attendance_summary_id" t-field="o.attendance_summary_id.working_days"/>
                            <span t-else="">—</span>
                        </td>
                        <td style="border:none; padding:4px 0;">
                            <strong>Department</strong> :
                            <span t-field="o.employee_id.department_id.name"/>
                        </td>
                    </tr>
                </table>

                <!-- ── Earnings / Deductions ──────────────────────────────── -->
                <table style="width:100%; border-collapse:collapse; font-size:16px; margin-bottom: 24px;">
                    <thead>
                        <tr>
                            <th style="border:1px solid #000; background-color:#d9d9d9; text-align:center; padding:8px;">Earnings</th>
                            <th style="border:1px solid #000; background-color:#d9d9d9; text-align:center; padding:8px;">Amount</th>
                            <th style="border:1px solid #000; background-color:#d9d9d9; text-align:center; padding:8px;">Deductions</th>
                            <th style="border:1px solid #000; background-color:#d9d9d9; text-align:center; padding:8px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="border:1px solid #000; padding:8px;">Basic Salary</td>
                            <td style="border:1px solid #000; padding:8px; text-align:right;">
                                <span t-esc="o._fmt_amount(o._get_salary_line_amount('BASIC'))"/>
                            </td>
                            <td style="border:1px solid #000; padding:8px;">Deduction (Leave)</td>
                            <td style="border:1px solid #000; padding:8px; text-align:right;">
                                <span t-esc="o._fmt_amount(o._get_salary_line_amount('ABSENT_DED'))"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000; padding:8px;"> </td>
                            <td style="border:1px solid #000; padding:8px;"> </td>
                            <td style="border:1px solid #000; padding:8px;">Deduction (Permission Overflow)</td>
                            <td style="border:1px solid #000; padding:8px; text-align:right;">
                                <span t-esc="o._fmt_amount(o._get_salary_line_amount('PERM_OVERFLOW_DED'))"/>
                            </td>
                        </tr>
                        <tr style="font-weight:bold;">
                            <td style="border:1px solid #000; padding:8px;">Total Earnings (Gross Salary)</td>
                            <td style="border:1px solid #000; padding:8px; text-align:right;">
                                <span t-esc="o._fmt_amount(o._get_salary_line_amount('GROSS'))"/>
                            </td>
                            <td style="border:1px solid #000; padding:8px;">Total Deductions</td>
                            <td style="border:1px solid #000; padding:8px; text-align:right;">
                                <span t-esc="o._fmt_amount(o._get_salary_category_amount('DED'))"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- ── Net Pay summary ────────────────────────────────────── -->
                <h5 style="font-size:18px;">Net Pay</h5>
                <table style="width:55%; border-collapse:collapse; font-size:16px; margin-bottom: 28px;">
                    <tr>
                        <th style="border:1px solid #000; background-color:#d9d9d9; text-align:left; padding:8px;">Description</th>
                        <th style="border:1px solid #000; background-color:#d9d9d9; text-align:right; padding:8px;">Amount (Rs.)</th>
                    </tr>
                    <tr>
                        <td style="border:1px solid #000; padding:8px;">Gross Salary</td>
                        <td style="border:1px solid #000; padding:8px; text-align:right;">
                            <span t-esc="o._fmt_amount(o._get_salary_line_amount('GROSS'))"/>
                        </td>
                    </tr>
                </table>

                <table style="width:55%; border-collapse:collapse; font-size:16px; margin-bottom: 24px;">
                    <tr>
                        <th style="border:1px solid #000; background-color:#d9d9d9; text-align:left; padding:8px;">Description</th>
                        <th style="border:1px solid #000; background-color:#d9d9d9; text-align:right; padding:8px;">Amount (Rs.)</th>
                    </tr>
                    <tr>
                        <td style="border:1px solid #000; padding:8px;">Total Deductions</td>
                        <td style="border:1px solid #000; padding:8px; text-align:right;">
                            <span t-esc="o._fmt_amount(o._get_salary_category_amount('DED'))"/>
                        </td>
                    </tr>
                    <tr style="font-weight:bold;">
                        <td style="border:1px solid #000; padding:8px;">Net Pay (Take-Home Salary)</td>
                        <td style="border:1px solid #000; padding:8px; text-align:right;">
                            <span t-esc="o._fmt_amount(o._get_salary_line_amount('NET'))"/>
                        </td>
                    </tr>
                </table>

                <p style="font-size:16px; margin-bottom:4px;"><strong>Net Pay in Words:</strong></p>
                <p style="font-size:16px; margin-bottom:24px;">
                    <span t-esc="o._get_amount_in_words(o._get_salary_line_amount('NET'))"/>
                </p>

                <h6 style="font-size:16px; margin:0 0 6px 0;">Notes</h6>
                <ul style="font-size:15px; margin:0; padding-left:20px;">
                    <li>This is a <strong>computer-generated payslip</strong> and does not require a physical signature.</li>
                    <li>Salary credited via bank transfer</li>
                </ul>

            </div>
        </xpath>
    </template>

</odoo>