<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Employee "My Payslips" action — list, kanban, form -->
    <record id="action_employee_own_payslips" model="ir.actions.act_window">
        <field name="name">My Payslips</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

    <menuitem
        id="menu_employee_own_payslips"
        name="My Payslips"
        parent="hr.menu_hr_root"
        action="action_employee_own_payslips"
        sequence="99"
        groups="base.group_user"/>

</odoo>