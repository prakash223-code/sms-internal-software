<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_hr_employee_form_custom_id" model="ir.ui.view">
    <field name="name">hr.employee.form.custom.id</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">

      <!-- ============================================================
           1. HEADER — Status bar + Confirm / Reset to Draft buttons
           ============================================================ -->
      <xpath expr="//header" position="inside">

        <!-- Confirm Employee: visible only in Draft state -->
        <button name="action_confirm"
                string="Confirm Employee"
                type="object"
                class="btn-primary"
                invisible="state != 'draft'"
                confirm="Are you sure you want to confirm this employee?
An Employee ID will be generated and the record will be locked.
Make sure the Department is correct before proceeding."/>

        <!-- Reset to Draft: visible only in Confirmed state (Manager only via Python) -->
        <button name="action_reset_to_draft"
                string="Reset to Draft"
                type="object"
                class="btn-secondary"
                invisible="state != 'confirmed'"
                confirm="Reset this employee to Draft? Their Employee ID will be cleared
and a new one will be generated on re-confirmation.
This is only allowed if no payroll, attendance, or leave data exists."/>

        <!-- Status bar -->
        <field name="state"
               widget="statusbar"
               statusbar_visible="draft,confirmed"/>

      </xpath>

      <!-- ============================================================
           2. BANNERS — shown above the sheet
           Draft:     amber warning — record incomplete, no ID yet
           Confirmed: green success — record locked, ID active
           ============================================================ -->
      <xpath expr="//sheet" position="before">

        <!-- Draft warning banner -->
        <div class="o_emp_banner o_emp_banner_draft"
             invisible="state != 'draft'">
          <i class="fa fa-exclamation-triangle" title="Warning"/>
          <div>
            <strong>Draft Record</strong> — This employee has not been confirmed yet.
            No Employee ID has been assigned. Please verify all details,
            especially the <strong>Department</strong>, before clicking
            <strong>Confirm Employee</strong>.
            Draft records can be freely deleted if created in error.
          </div>
        </div>

        <!-- Confirmed success banner -->
        <div class="o_emp_banner o_emp_banner_confirmed"
             invisible="state != 'confirmed'">
          <i class="fa fa-check-circle" title="Confirmed"/>
          <div>
            Employee confirmed and active.
            The Employee ID is permanent — department and ID cannot be changed.
            To transfer departments, archive this record and create a new entry.
          </div>
        </div>

      </xpath>

      <!-- ============================================================
           3. EMPLOYEE ID — shown below the name field
           Draft:     dashed pending pill
           Confirmed: blue ID card with icon + monospaced code
           ============================================================ -->
      <xpath expr="//field[@name='name']" position="after">

        <!-- Hidden field needed for invisible expressions below -->
        <field name="state" invisible="1"/>

        <!-- Confirmed: styled ID card -->
        <div class="o_emp_id_block" invisible="state != 'confirmed'">
          <div class="o_emp_id_icon">
            <i class="fa fa-id-badge" title="Employee ID"/>
          </div>
          <div class="o_emp_id_text_group">
            <div class="o_emp_id_label">Employee ID</div>
            <div class="o_emp_id_value">
              <field name="employee_code" readonly="1" nolabel="1"/>
            </div>
          </div>
        </div>

        <!-- Draft: pending pill -->
        <div class="o_emp_pending_text" invisible="state != 'draft'">
          <i class="fa fa-clock-o" title="Pending"/>
          Employee ID will be generated on confirmation
        </div>

      </xpath>

      <!-- ============================================================
           4. DEPARTMENT — lock after confirmation
           HR cannot change department once the ID is generated
           because the ID encodes the department code.
           ============================================================ -->
      <xpath expr="//field[@name='department_id']" position="attributes">
        <attribute name="readonly">state == 'confirmed'</attribute>
        <attribute name="help">Department cannot be changed after confirmation because the Employee ID is generated from the department code.</attribute>
      </xpath>

    </field>
  </record>
</odoo>