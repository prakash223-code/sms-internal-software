<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_hr_employee_form_custom_id" model="ir.ui.view">
    <field name="name">hr.employee.form.custom.id</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
      <!-- Insert Employee ID right after the name field -->
      <xpath expr="//field[@name='name']" position="after">
        <field name="employee_code"
               string="Employee ID"
               readonly="1"
               widget="badge"/>
      </xpath>
    </field>
  </record>
</odoo>