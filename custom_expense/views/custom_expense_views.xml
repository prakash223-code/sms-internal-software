<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_custom_expense_list" model="ir.ui.view">
        <field name="name">custom.expense.list</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="date"/>
                <field name="submitted_by"/>
                <field name="category_id"/>
                <field name="project_id" optional="show"/>
                <field name="amount"/>
                <field name="currency_id" optional="hide"/>
                <field name="attachment_count" string="Attachments"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_custom_expense_kanban" model="ir.ui.view">
        <field name="name">custom.expense.kanban</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">

            <kanban default_group_by="state"
                    class="o_kanban_small_column">

                <field name="name"/>
                <field name="date"/>
                <field name="submitted_by"/>
                <field name="category_id"/>
                <field name="project_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="attachment_count"/>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_card oe_kanban_global_click
                                rounded-4 shadow-sm border-0 p-3">

                            <!-- Top Section -->
                            <div class="d-flex justify-content-between align-items-start">

                                <!-- Left -->
                                <div class="me-2">

                                    <div class="fw-bold fs-5 text-truncate">
                                        <field name="name"/>
                                    </div>

                                    <div class="text-muted small">
                                        <i class="fa fa-calendar me-1" title="Date"/>
                                        <field name="date"/>
                                    </div>

                                </div>

                                <!-- Right Status -->
                                <div>
                                    <field name="state"
                                           widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'submitted'"
                                           decoration-success="state == 'approved'"
                                           decoration-danger="state == 'rejected'"/>
                                </div>

                            </div>

                            <!-- Amount -->
                            <div class="mt-3">

                                <div class="text-muted small">
                                    Expense Amount
                                </div>

                                <div class="fw-bold fs-2 text-primary">
                                    <field name="amount"/>
                                    <field name="currency_id"/>
                                </div>

                            </div>

                            <!-- Divider -->
                            <div class="border-top my-3"/>

                            <!-- Employee -->
                            <div class="d-flex align-items-center mb-2">

                                <div class="me-2 text-muted">
                                    <i class="fa fa-user" title="Employee"/>
                                </div>

                                <div class="text-truncate">
                                    <field name="submitted_by"/>
                                </div>

                            </div>

                            <!-- Category -->
                            <div class="d-flex align-items-center mb-2">

                                <div class="me-2 text-muted">
                                    <i class="fa fa-tags" title="Category"/>
                                </div>

                                <div class="text-truncate">
                                    <field name="category_id"/>
                                </div>

                            </div>

                            <!-- Project -->
                            <div class="d-flex align-items-center mb-2"
                                 invisible="not project_id">

                                <div class="me-2 text-muted">
                                    <i class="fa fa-folder-open" title="Project"/>
                                </div>

                                <div class="text-truncate">
                                    <field name="project_id"/>
                                </div>

                            </div>

                            <!-- Footer -->
                            <div class="d-flex justify-content-between
                                    align-items-center mt-3 pt-2 border-top">

                                <!-- Attachments -->
                                <div class="text-muted small">

                                    <i class="fa fa-paperclip me-1" title="Attachments"/>

                                    <field name="attachment_count"/>
                                    Files

                                </div>

                                <!-- Quick Status Indicator -->
                                <div>

                                    <span invisible="state != 'approved'"
                                          class="badge bg-success">
                                        Approved
                                    </span>

                                    <span invisible="state != 'submitted'"
                                          class="badge bg-warning text-dark">
                                        Waiting
                                    </span>

                                    <span invisible="state != 'rejected'"
                                          class="badge bg-danger">
                                        Rejected
                                    </span>

                                    <span invisible="state != 'draft'"
                                          class="badge bg-secondary">
                                        Draft
                                    </span>

                                </div>

                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_custom_expense_pivot" model="ir.ui.view">
        <field name="name">custom.expense.pivot</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">
            <pivot string="Expense Analysis">

                <field name="amount" type="measure"/>

                <field name="submitted_by" type="row"/>
                <field name="category_id" type="row"/>

                <field name="date" interval="month" type="col"/>

            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_custom_expense_graph" model="ir.ui.view">
        <field name="name">custom.expense.graph</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">
            <graph string="Expense Analysis" type="bar">

                <field name="category_id"/>
                <field name="amount" type="measure"/>

            </graph>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_custom_expense_form" model="ir.ui.view">
        <field name="name">custom.expense.form</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">
            <form string="Company Expense">
                <header>
                    <button name="action_submit"
                            string="Submit for Approval"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'rejected'"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Expense Details">
                            <field name="submitted_by"
                                   readonly="state != 'draft'"
                                   groups="hr.group_hr_manager"/>
                            <field name="submitted_by"
                                   readonly="1"
                                   groups="base.group_user"/>
                            <field name="category_id" readonly="state != 'draft'"/>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group string="Amount">
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="currency_id"
                                   readonly="state != 'draft'"
                                   groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description"
                               nolabel="1"
                               readonly="state != 'draft'"
                               placeholder="Describe the expense purpose..."/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids"
                               widget="many2many_binary"
                               readonly="state != 'draft'"
                               nolabel="1"/>
                    </group>
                    <group string="Rejection Details" invisible="state != 'rejected'">
                        <field name="rejection_reason" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_custom_expense_search" model="ir.ui.view">
        <field name="name">custom.expense.search</field>
        <field name="model">custom.expense</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <field name="project_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state','=','submitted')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="filter_rejected" string="Rejected" domain="[('state','=','rejected')]"/>
            </search>
        </field>
    </record>

    <!-- HR/Employee Action -->
    <record id="action_custom_expense_hr" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">custom.expense</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="context">{'search_default_filter_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No expenses found. Create your first expense!
            </p>
        </field>
    </record>

    <!-- Manager Action -->
    <record id="action_custom_expense_manager" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">custom.expense</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="context">{'search_default_filter_submitted': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No expenses pending approval.
            </p>
        </field>
    </record>

</odoo>