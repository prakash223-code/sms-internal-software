<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_custom_expense" model="ir.sequence">
        <field name="name">Company Expense</field>
        <field name="code">custom.expense</field>
        <field name="prefix">EXP/%(year)s/</field>
